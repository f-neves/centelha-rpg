---
import Base from '../layouts/Base.astro';
---
<Base title="Mesa" largura="wide" descricao="Página da mesa: membros, personagens e recursos.">
  <div id="setup" class="aviso" hidden>
    <strong>Área de contas ainda não configurada.</strong>
    <p class="muted">Falta ligar o Supabase. Veja <code>supabase/README.md</code>.</p>
  </div>

  <div id="carregando" class="muted">Carregando…</div>
  <div id="erro" class="erro" hidden></div>

  <div id="mesa" hidden>
    <header class="mesa-cab">
      <div>
        <span id="papel" class="papel"></span>
        <h1 id="nome" class="cinzel" style="margin:.2rem 0 0"></h1>
        <p id="descricao" class="muted"></p>
      </div>
      <div class="mesa-cab-acoes">
        <div id="box-convite" class="convite" hidden>
          <span class="muted">Código de convite</span>
          <div class="convite-linha">
            <code id="codigo"></code>
            <button class="btn" id="btn-copiar" title="Copiar código">Copiar</button>
          </div>
        </div>
        <button class="btn" id="btn-sair-mesa" hidden>Sair da mesa</button>
      </div>
    </header>

    <section class="bloco">
      <h2>Membros</h2>
      <ul id="membros" class="membros"></ul>
    </section>

    <section class="bloco">
      <div class="bloco-cab">
        <h2>Personagens</h2>
        <button class="btn primary" id="btn-novo-pers">Novo personagem</button>
      </div>
      <div id="personagens"></div>
    </section>

    <section class="bloco">
      <div class="bloco-cab">
        <h2>Arquivos da mesa</h2>
        <label class="btn primary" id="mesa-arq-lbl" hidden>Enviar arquivo
          <input type="file" id="mesa-arq-file" hidden />
        </label>
      </div>
      <p class="muted" id="mesa-arq-dica" hidden>Marque a caixa "visível" para liberar o arquivo aos jogadores. Sem marcar, só você (mestre) vê.</p>
      <ul id="mesa-arqs" class="arqs"></ul>
    </section>

    <section class="bloco escudo">
      <div class="bloco-cab">
        <h2>Escudo do Mestre <small>· criaturas da campanha</small></h2>
      </div>
      <div id="escudo-busca-wrap" class="escudo-busca-wrap" hidden>
        <input type="search" id="escudo-busca" placeholder="Buscar criatura no bestiário para adicionar…" autocomplete="off" />
        <ul id="escudo-result" class="escudo-result" hidden></ul>
      </div>
      <div id="escudo-lista" class="escudo-lista"></div>
    </section>
  </div>
</Base>

<script>
  import { getSupabase } from '../lib/supabase';
  import { exigirLogin, supabaseConfigurado } from '../lib/auth';
  import monstersData from '../data/monsters.json';

  const base = import.meta.env.BASE_URL;
  const u = (p: string) => `${base.replace(/\/$/, '')}/${p}`;
  const esc = (s: string) => (s || '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
  const norm = (s: string) => (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  const id = new URLSearchParams(location.search).get('id');

  const MON: Record<string, any> = Object.fromEntries((monstersData as any[]).map((m) => [m.id, m]));
  const MON_LIST = (monstersData as any[]).map((m) => ({ id: m.id, nome: m.nome, nomeIngles: m.nomeIngles || '', ameaca: m.ameaca }));

  const mostraErro = (t: string) => {
    document.getElementById('carregando')!.hidden = true;
    const el = document.getElementById('erro')!; el.hidden = false; el.textContent = t;
  };

  async function main() {
    if (!supabaseConfigurado) {
      document.getElementById('carregando')!.hidden = true;
      document.getElementById('setup')!.hidden = false;
      return;
    }
    if (!id) return mostraErro('Mesa não informada.');
    const user = await exigirLogin(base);
    if (!user) return;

    const sb = getSupabase();
    const { data: mesa, error } = await sb.from('mesas').select('*').eq('id', id).maybeSingle();
    if (error) return mostraErro('Erro: ' + error.message);
    if (!mesa) return mostraErro('Mesa não encontrada ou você não tem acesso a ela.');

    const ehMestre = mesa.mestre_id === user.id;
    document.getElementById('carregando')!.hidden = true;
    document.getElementById('mesa')!.hidden = false;
    document.getElementById('nome')!.textContent = mesa.nome;
    document.getElementById('descricao')!.textContent = mesa.descricao || '';
    const papel = document.getElementById('papel')!;
    papel.textContent = ehMestre ? 'Mestre' : 'Jogador';
    papel.classList.add(ehMestre ? 'p-mestre' : 'p-jogador');

    if (ehMestre) {
      const box = document.getElementById('box-convite')!; box.hidden = false;
      document.getElementById('codigo')!.textContent = mesa.codigo_convite;
      document.getElementById('btn-copiar')!.addEventListener('click', async () => {
        try { await navigator.clipboard.writeText(mesa.codigo_convite); (document.getElementById('btn-copiar') as HTMLButtonElement).textContent = 'Copiado!'; setTimeout(() => (document.getElementById('btn-copiar')!.textContent = 'Copiar'), 1400); } catch {}
      });
    } else {
      const sairBtn = document.getElementById('btn-sair-mesa')! as HTMLButtonElement;
      sairBtn.hidden = false;
      sairBtn.addEventListener('click', async () => {
        if (!confirm('Sair desta mesa? Seus personagens deixam de ficar ligados a ela.')) return;
        await sb.from('mesa_membros').delete().eq('mesa_id', id).eq('user_id', user.id);
        location.href = u('mesas');
      });
    }

    await renderMembros(sb, mesa.mestre_id);

    document.getElementById('btn-novo-pers')!.addEventListener('click', () => {
      location.href = u('personagem') + '?novo=1&mesa=' + id;
    });
    await renderPersonagens(sb, ehMestre, user.id);

    if (ehMestre) {
      document.getElementById('mesa-arq-lbl')!.hidden = false;
      document.getElementById('mesa-arq-dica')!.hidden = false;
      (document.getElementById('mesa-arq-file') as HTMLInputElement).addEventListener('change', (e) => subirArquivoMesa(sb, user.id, (e.target as HTMLInputElement).files?.[0]));
    }
    await listarArquivosMesa(sb, ehMestre);

    if (ehMestre) {
      document.getElementById('escudo-busca-wrap')!.hidden = false;
      const busca = document.getElementById('escudo-busca') as HTMLInputElement;
      const res = document.getElementById('escudo-result')!;
      busca.addEventListener('input', () => {
        const q = norm(busca.value.trim());
        if (q.length < 2) { res.hidden = true; return; }
        const hits = MON_LIST.filter((m) => norm(m.nome).includes(q) || norm(m.nomeIngles).includes(q)).slice(0, 8);
        res.innerHTML = hits.length
          ? hits.map((m) => `<li data-mon="${m.id}">${esc(m.nome)}${m.nomeIngles && m.nomeIngles !== m.nome ? ` <span class="muted">(${esc(m.nomeIngles)})</span>` : ''} <span class="muted">· A${m.ameaca}</span></li>`).join('')
          : '<li class="muted vazio">nada encontrado</li>';
        res.hidden = false;
        res.querySelectorAll<HTMLElement>('li[data-mon]').forEach((li) => li.addEventListener('click', () => addCriatura(sb, li.dataset.mon!)));
      });
      document.addEventListener('click', (e) => { if (!(e.target as HTMLElement).closest('#escudo-busca-wrap')) res.hidden = true; });
    }
    await renderEscudo(sb, ehMestre);
  }

  async function addCriatura(sb: any, monId: string) {
    const { error } = await sb.from('mesa_criaturas').insert({ mesa_id: id, monstro_id: monId });
    if (error && !/duplicate|unique/i.test(error.message)) return alert('Erro: ' + error.message);
    (document.getElementById('escudo-busca') as HTMLInputElement).value = '';
    document.getElementById('escudo-result')!.hidden = true;
    await renderEscudo(sb, true);
  }

  async function renderEscudo(sb: any, ehMestre: boolean) {
    const { data, error } = await sb.from('mesa_criaturas').select('*').eq('mesa_id', id)
      .order('ordem', { ascending: true }).order('criado_em', { ascending: true });
    const box = document.getElementById('escudo-lista')!;
    if (error) { box.innerHTML = `<p class="erro">${esc(error.message)}</p>`; return; }
    if (!data?.length) {
      box.innerHTML = ehMestre
        ? '<p class="muted">Nenhuma criatura separada ainda. Busque acima para montar seu bestiário da campanha.</p>'
        : '<p class="muted">O mestre ainda não separou criaturas.</p>';
      return;
    }
    box.innerHTML = data.map((c: any) => {
      const m = MON[c.monstro_id];
      if (!m) return `<div class="cr-card"><span class="muted">Criatura removida do bestiário (${esc(c.monstro_id)})</span>${ehMestre ? ` <button class="btn cr-rm" data-cr="${c.id}">✕</button>` : ''}</div>`;
      const cb = m.combate || {};
      const badges = `<span class="cr-b">A${m.ameaca}</span><span class="cr-b">Centelha ${m.centelha}</span><span class="cr-b">PV ${cb.pv ?? '-'}</span><span class="cr-b">Def ${cb.defesa ?? '-'}</span>${m.porte ? `<span class="cr-b">${esc(m.porte)}</span>` : ''}`;
      const notas = ehMestre
        ? `<textarea class="cr-notas" data-cr="${c.id}" rows="2" placeholder="Anotações do mestre (só você vê nesta lista)">${esc(c.notas || '')}</textarea>`
        : (c.notas ? `<p class="cr-notas-ro">${esc(c.notas)}</p>` : '');
      return `<div class="cr-card">
        <div class="cr-top">
          <span class="cr-nome cinzel">${esc(m.nome)}${m.nomeIngles && m.nomeIngles !== m.nome ? ` <span class="muted cr-en">(${esc(m.nomeIngles)})</span>` : ''}</span>
          ${ehMestre ? `<button class="btn cr-rm" data-cr="${c.id}" title="Remover">✕</button>` : ''}
        </div>
        <div class="cr-badges">${badges}</div>
        <a class="cr-link" href="${u('bestiario')}#${m.id}">ver no bestiário ›</a>
        ${notas}
      </div>`;
    }).join('');

    box.querySelectorAll<HTMLElement>('.cr-rm').forEach((b) => b.addEventListener('click', async () => {
      if (!confirm('Remover esta criatura da campanha?')) return;
      await sb.from('mesa_criaturas').delete().eq('id', b.dataset.cr);
      await renderEscudo(sb, true);
    }));
    box.querySelectorAll<HTMLTextAreaElement>('.cr-notas').forEach((ta) => {
      let t: any; ta.addEventListener('input', () => { clearTimeout(t); t = setTimeout(async () => { await sb.from('mesa_criaturas').update({ notas: ta.value }).eq('id', ta.dataset.cr); }, 700); });
    });
  }

  async function subirArquivoMesa(sb: any, userId: string, file?: File) {
    if (!file) return;
    const nomeSeguro = file.name.replace(/[^\w.\-]+/g, '_');
    const path = `${id}/${Date.now()}-${nomeSeguro}`;
    const { error } = await sb.storage.from('mesa').upload(path, file, { contentType: file.type });
    if (error) return alert('Erro ao enviar: ' + error.message);
    const { error: e2 } = await sb.from('arquivos').insert({
      mesa_id: id, dono_id: userId, nome: file.name, storage_path: path,
      bucket: 'mesa', tipo: file.type, categoria: 'handout-mestre', visivel_jogadores: false,
    });
    if (e2) return alert('Enviado, mas erro ao registrar: ' + e2.message);
    await listarArquivosMesa(sb, true);
  }

  async function listarArquivosMesa(sb: any, ehMestre: boolean) {
    const { data, error } = await sb.from('arquivos').select('*').eq('mesa_id', id).eq('bucket', 'mesa').order('criado_em', { ascending: false });
    const ul = document.getElementById('mesa-arqs')!;
    if (error) { ul.innerHTML = `<li class="erro">${esc(error.message)}</li>`; return; }
    if (!data?.length) { ul.innerHTML = `<li class="muted">${ehMestre ? 'Nenhum arquivo ainda. Envie handouts, mapas, documentos.' : 'O mestre ainda não compartilhou arquivos.'}</li>`; return; }
    ul.innerHTML = data.map((a: any) => `<li data-arq="${a.id}" data-path="${esc(a.storage_path)}">
      <a href="#" class="arq-abrir">${esc(a.nome)}</a>
      <span class="muted arq-tipo">${esc((a.tipo || '').split('/')[1] || '')}</span>
      ${ehMestre ? `<label class="arq-vis" title="Visível aos jogadores"><input type="checkbox" class="arq-vis-cb"${a.visivel_jogadores ? ' checked' : ''}/> visível</label><button class="btn arq-rm" title="Remover">✕</button>` : ''}
    </li>`).join('');
    ul.querySelectorAll<HTMLElement>('.arq-abrir').forEach((a) => a.addEventListener('click', async (e) => {
      e.preventDefault();
      const li = a.closest('li')!; const { data: s } = await sb.storage.from('mesa').createSignedUrl(li.dataset.path!, 3600);
      if (s?.signedUrl) window.open(s.signedUrl, '_blank');
    }));
    ul.querySelectorAll<HTMLInputElement>('.arq-vis-cb').forEach((cb) => cb.addEventListener('change', async () => {
      const li = cb.closest('li')!;
      await sb.from('arquivos').update({ visivel_jogadores: cb.checked }).eq('id', li.dataset.arq);
    }));
    ul.querySelectorAll<HTMLElement>('.arq-rm').forEach((b) => b.addEventListener('click', async () => {
      const li = b.closest('li')!;
      if (!confirm('Remover este arquivo?')) return;
      await sb.storage.from('mesa').remove([li.dataset.path!]);
      await sb.from('arquivos').delete().eq('id', li.dataset.arq);
      await listarArquivosMesa(sb, true);
    }));
  }

  async function renderPersonagens(sb: any, ehMestre: boolean, userId: string) {
    const { data, error } = await sb
      .from('personagens')
      .select('id, nome, conceito, dono_id, imagem_path')
      .eq('mesa_id', id)
      .order('atualizado_em', { ascending: false });
    const box = document.getElementById('personagens')!;
    if (error) { box.innerHTML = `<p class="erro">${esc(error.message)}</p>`; return; }
    const nomes = await nomesDe(sb, (data || []).map((p: any) => p.dono_id));
    if (!data?.length) {
      box.innerHTML = ehMestre
        ? '<p class="muted">Nenhum personagem nesta mesa ainda. Os jogadores criam os seus, ou crie um você mesmo.</p>'
        : '<p class="muted">Você ainda não tem personagem nesta mesa. Clique em "Novo personagem".</p>';
      return;
    }
    box.innerHTML = '<div class="pers-grid">' + data.map((p: any) => {
      const dono = nomes[p.dono_id] || '(jogador)';
      const meu = p.dono_id === userId;
      return `<a class="pers-card" href="${u('personagem')}?id=${p.id}">
        <span class="pers-card-nome cinzel">${esc(p.nome || 'Personagem')}</span>
        ${p.conceito ? `<span class="pers-card-conc">${esc(p.conceito)}</span>` : ''}
        <span class="pers-card-dono muted">${meu ? 'Seu personagem' : 'Jogador: ' + esc(dono)}</span>
      </a>`;
    }).join('') + '</div>';
  }

  async function nomesDe(sb: any, ids: string[]): Promise<Record<string, string>> {
    const uniq = [...new Set(ids.filter(Boolean))];
    if (!uniq.length) return {};
    const { data } = await sb.from('profiles').select('id, nome').in('id', uniq);
    return Object.fromEntries((data || []).map((p: any) => [p.id, p.nome]));
  }

  async function renderMembros(sb: any, mestreId: string) {
    const { data, error } = await sb
      .from('mesa_membros')
      .select('papel, user_id')
      .eq('mesa_id', id)
      .order('entrou_em', { ascending: true });
    const ul = document.getElementById('membros')!;
    if (error) { ul.innerHTML = `<li class="erro">${esc(error.message)}</li>`; return; }
    const nomes = await nomesDe(sb, (data || []).map((m: any) => m.user_id));
    ul.innerHTML = (data || []).map((m: any) => {
      const nome = nomes[m.user_id] || '(sem nome)';
      const mestre = m.papel === 'mestre' || m.user_id === mestreId;
      return `<li><span class="papel ${mestre ? 'p-mestre' : 'p-jogador'}">${mestre ? 'Mestre' : 'Jogador'}</span> ${esc(nome)}</li>`;
    }).join('');
  }

  main();
</script>

<!-- is:global: cabeçalho e listas são preenchidos via JS -->
<style is:global>
  .mesa-cab { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; border-bottom: 1px solid var(--rule); padding-bottom: 1rem; margin-bottom: 1rem; }
  .mesa-cab-acoes { display: flex; flex-direction: column; gap: .6rem; align-items: flex-end; }
  .convite { text-align: right; }
  .convite-linha { display: flex; align-items: center; gap: .5rem; }
  .convite code { font-size: 1.25rem; letter-spacing: .12em; background: var(--panel); border: 1px solid var(--rule); border-radius: 6px; padding: .2rem .6rem; }
  .bloco { margin-top: 1.4rem; }
  .bloco-cab { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .pers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; margin-top: .8rem; }
  .pers-card { display: flex; flex-direction: column; gap: .25rem; padding: .9rem 1rem; border: 1px solid var(--rule); border-radius: 10px; background: var(--panel); text-decoration: none; color: var(--ink); transition: border-color .15s, transform .15s; }
  .pers-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .pers-card-nome { font-size: 1.1rem; font-weight: 700; }
  .pers-card-conc { color: var(--ink-soft); font-size: .9rem; font-style: italic; }
  .pers-card-dono { font-size: .8rem; }
  .arqs { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .3rem; margin-top: .6rem; }
  .arqs li { display: flex; align-items: center; gap: .6rem; padding: .35rem 0; border-bottom: 1px solid var(--rule); }
  .arqs .arq-abrir { flex: 1; color: var(--accent); text-decoration: none; }
  .arqs .arq-tipo { font-size: .78rem; text-transform: uppercase; }
  .arqs .arq-vis { display: inline-flex; align-items: center; gap: .25rem; font-size: .82rem; color: var(--ink-soft); }
  .arqs .arq-rm { background: none; border: none; color: #b3261e; cursor: pointer; }
  .membros { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .4rem; }
  .membros li { display: flex; align-items: center; gap: .5rem; padding: .35rem 0; border-bottom: 1px solid var(--rule); }
  .papel { font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; padding: .1rem .5rem; border-radius: 999px; font-weight: 700; }
  .p-mestre { background: color-mix(in srgb, var(--gold, #b8860b) 25%, transparent); color: var(--ink); }
  .p-jogador { background: color-mix(in srgb, var(--accent) 20%, transparent); color: var(--ink); }
  .aviso { border: 1px solid var(--gold, var(--rule)); border-radius: 8px; padding: 1rem; background: color-mix(in srgb, var(--gold, #caa) 12%, transparent); max-width: 40rem; }
  .erro { color: #b3261e; }

  .escudo-busca-wrap { position: relative; max-width: 30rem; margin: .4rem 0 1rem; }
  .escudo-busca-wrap input { width: 100%; padding: .5rem; border: 1px solid var(--rule); border-radius: 6px; background: var(--bg); color: var(--ink); font: inherit; }
  .escudo-result { position: absolute; z-index: 20; left: 0; right: 0; margin: .2rem 0 0; padding: 0; list-style: none; background: var(--panel); border: 1px solid var(--rule); border-radius: 6px; max-height: 16rem; overflow: auto; box-shadow: 0 6px 20px rgba(0,0,0,.15); }
  .escudo-result li { padding: .45rem .7rem; cursor: pointer; }
  .escudo-result li:hover { background: color-mix(in srgb, var(--accent) 14%, transparent); }
  .escudo-result li.vazio { cursor: default; }
  .escudo-lista { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
  .cr-card { border: 1px solid var(--rule); border-radius: 10px; padding: .8rem .9rem; background: var(--panel); display: flex; flex-direction: column; gap: .4rem; }
  .cr-top { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; }
  .cr-nome { font-size: 1.05rem; font-weight: 700; }
  .cr-en { font-size: .82rem; font-weight: 400; font-style: italic; }
  .cr-badges { display: flex; flex-wrap: wrap; gap: .3rem; }
  .cr-b { font-family: 'Cinzel'; font-size: .68rem; letter-spacing: .03em; padding: .1rem .45rem; border-radius: 999px; background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--ink); }
  .cr-link { color: var(--accent); text-decoration: none; font-size: .85rem; }
  .cr-notas { font: inherit; font-family: 'EB Garamond'; padding: .4rem; border: 1px solid var(--rule); border-radius: 6px; background: var(--bg); color: var(--ink); resize: vertical; }
  .cr-notas-ro { font-size: .9rem; color: var(--ink-soft); font-style: italic; margin: 0; }
  .cr-rm { background: none; border: none; color: #b3261e; cursor: pointer; padding: 0 .2rem; }
</style>
