---
import Base from '../layouts/Base.astro';
import FichaSkeleton from '../components/FichaSkeleton.astro';
---
<Base title="Personagem" largura="wide" descricao="Ficha do personagem ligada à sua conta.">
  <div id="setup" class="aviso" hidden>
    <strong>Área de contas ainda não configurada.</strong>
    <p class="muted">Falta ligar o Supabase. Veja <code>supabase/README.md</code>.</p>
  </div>

  <div id="carregando" class="muted">Carregando…</div>
  <div id="erro" class="erro" hidden></div>

  <div id="pg" hidden>
    <p class="voltar"><a id="link-mesa" href="#">‹ voltar</a></p>

    <header class="pers-cab">
      <div class="retrato">
        <img id="retrato-img" alt="Retrato do personagem" hidden />
        <div id="retrato-vazio" class="retrato-vazio">Sem imagem</div>
        <label class="btn retrato-btn" id="retrato-lbl" hidden>Trocar imagem
          <input type="file" id="retrato-file" accept="image/*" hidden />
        </label>
      </div>
      <div class="pers-tit">
        <span id="pers-mesa" class="muted"></span>
        <h1 id="pers-nome" class="cinzel">Personagem</h1>
        <span id="xp-nota" class="xp-nota"></span>
        <div id="mestre-xp" class="mestre-xp" hidden>
          <label>XP do personagem <input type="number" id="xp-input" min="0" /></label>
          <button class="btn primary" id="xp-salvar">Salvar XP</button>
          <span id="xp-salvo" class="salvo"></span>
        </div>
      </div>
    </header>

    <div id="somente-leitura" class="aviso" hidden>
      <strong>Visão do mestre.</strong>
      <p class="muted">Você vê a ficha e os arquivos deste personagem, mas quem edita a ficha é o jogador dono. Você define o XP acima.</p>
    </div>

    <div id="ficha-wrap" hidden>
      <FichaSkeleton />
    </div>

    <section class="bloco">
      <h2 class="barh">Descrição, História, Background &amp; Anotações</h2>
      <div class="textos">
        <label>Descrição<textarea data-campo="descricao" rows="4" placeholder="Aparência, personalidade, traços marcantes…"></textarea></label>
        <label>História<textarea data-campo="historia" rows="6" placeholder="De onde vem, o que viveu…"></textarea></label>
        <label>Background<textarea data-campo="background" rows="5" placeholder="Origem, laços, motivações…"></textarea></label>
        <label>Anotações<textarea data-campo="anotacoes" rows="5" placeholder="Notas livres do jogador…"></textarea></label>
      </div>
      <span id="txt-status" class="salvo"></span>
    </section>

    <section class="bloco">
      <h2 class="barh">Arquivos <small>(imagens, PDFs, documentos)</small></h2>
      <label class="btn" id="arq-lbl" hidden>Enviar arquivo
        <input type="file" id="arq-file" hidden />
      </label>
      <ul id="arqs" class="arqs"></ul>
    </section>
  </div>
</Base>

<script>
  import { getSupabase } from '../lib/supabase';
  import { montarFicha } from '../lib/ficha-engine';
  import { exigirLogin, supabaseConfigurado } from '../lib/auth';

  const base = import.meta.env.BASE_URL;
  const u = (p: string) => `${base.replace(/\/$/, '')}/${p}`;
  const esc = (s: string) => (s || '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
  const debounce = (fn: (...a: any[]) => void, ms: number) => { let t: any; return (...a: any[]) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; };
  const q = new URLSearchParams(location.search);
  const mostraErro = (t: string) => { document.getElementById('carregando')!.hidden = true; const el = document.getElementById('erro')!; el.hidden = false; el.textContent = t; };
  const BUCKET = 'personagens';

  async function main() {
    if (!supabaseConfigurado) { document.getElementById('carregando')!.hidden = true; document.getElementById('setup')!.hidden = false; return; }
    const user = await exigirLogin(base);
    if (!user) return;
    const sb = getSupabase();

    // Criação de personagem novo: ?novo=1[&mesa=<id>]
    let id = q.get('id');
    if (!id && q.get('novo')) {
      const mesa = q.get('mesa');
      const { data, error } = await sb.from('personagens')
        .insert({ dono_id: user.id, mesa_id: mesa || null, nome: 'Novo personagem' })
        .select('id').single();
      if (error) return mostraErro('Não deu para criar o personagem: ' + error.message);
      location.replace(u('personagem') + '?id=' + data.id);
      return;
    }
    if (!id) return mostraErro('Personagem não informado.');

    const { data: pers, error } = await sb.from('personagens').select('*').eq('id', id).maybeSingle();
    if (error) return mostraErro('Erro: ' + error.message);
    if (!pers) return mostraErro('Personagem não encontrado ou você não tem acesso a ele.');

    const ehDono = pers.dono_id === user.id;
    document.getElementById('carregando')!.hidden = true;
    document.getElementById('pg')!.hidden = false;

    // voltar
    const linkMesa = document.getElementById('link-mesa') as HTMLAnchorElement;
    if (pers.mesa_id) { linkMesa.href = u('mesa') + '?id=' + pers.mesa_id; linkMesa.textContent = '‹ voltar à mesa'; }
    else { linkMesa.href = u('mesas'); linkMesa.textContent = '‹ minhas mesas'; }

    document.getElementById('pers-nome')!.textContent = pers.nome || 'Personagem';

    // nome da mesa (se houver) + saber se o espectador é o mestre da mesa
    let ehMestre = false;
    if (pers.mesa_id) {
      const { data: mesa } = await sb.from('mesas').select('nome, mestre_id').eq('id', pers.mesa_id).maybeSingle();
      if (mesa) {
        document.getElementById('pers-mesa')!.textContent = 'Mesa: ' + mesa.nome;
        ehMestre = mesa.mestre_id === user.id;
      }
    } else {
      document.getElementById('pers-mesa')!.textContent = 'Sem mesa (personagem avulso)';
    }

    // retrato
    if (pers.imagem_path) await mostrarRetrato(sb, pers.imagem_path);
    if (ehDono) {
      document.getElementById('retrato-lbl')!.hidden = false;
      (document.getElementById('retrato-file') as HTMLInputElement).addEventListener('change', (e) => subirRetrato(sb, id!, (e.target as HTMLInputElement).files?.[0]));
    }

    // XP: se estiver em mesa, o mestre define (input travado); senão o jogador escolhe.
    let budgetValor: number | null = null;
    let budgetLocked = false;
    if (pers.mesa_id) {
      budgetLocked = true;
      const { data: xpRow } = await sb.from('personagem_xp').select('xp').eq('personagem_id', id).maybeSingle();
      budgetValor = xpRow?.xp ?? 0;
      document.getElementById('xp-nota')!.textContent = xpRow ? `XP definido pelo mestre: ${budgetValor}` : 'Aguardando o mestre definir seu XP.';
    }

    // textos
    (['descricao', 'historia', 'background', 'anotacoes'] as const).forEach((campo) => {
      const ta = document.querySelector<HTMLTextAreaElement>(`textarea[data-campo="${campo}"]`)!;
      ta.value = pers[campo] || '';
      if (!ehDono) { ta.readOnly = true; return; }
      const salvarTexto = debounce(async (valor: string) => {
        await sb.from('personagens').update({ [campo]: valor }).eq('id', id);
        const st = document.getElementById('txt-status')!; st.textContent = 'Salvo'; setTimeout(() => (st.textContent = ''), 1200);
      }, 700);
      ta.addEventListener('input', () => salvarTexto(ta.value));
    });

    // arquivos
    if (ehDono) {
      document.getElementById('arq-lbl')!.hidden = false;
      (document.getElementById('arq-file') as HTMLInputElement).addEventListener('change', (e) => subirArquivo(sb, id!, pers.mesa_id, user.id, (e.target as HTMLInputElement).files?.[0]));
    }
    await listarArquivos(sb, id, ehDono);

    // ficha
    if (ehDono) {
      document.getElementById('ficha-wrap')!.hidden = false;
      const salvarFicha = debounce(async (S: any) => {
        await sb.from('personagens').update({
          ficha: S,
          nome: (S.id?.nome || pers.nome || 'Personagem'),
          conceito: (S.id?.conceito || ''),
          atualizado_em: new Date().toISOString(),
        }).eq('id', id);
        document.getElementById('pers-nome')!.textContent = S.id?.nome || pers.nome || 'Personagem';
      }, 900);
      montarFicha({
        carregar: () => (pers.ficha && Object.keys(pers.ficha).length ? pers.ficha : null),
        salvar: (S) => salvarFicha(S),
        budgetLocked, budgetValor,
        aoResetar: () => {},
      });
    } else if (ehMestre) {
      // Visão do mestre sobre a ficha de outro jogador: leitura
      document.getElementById('somente-leitura')!.hidden = false;
      document.getElementById('ficha-wrap')!.hidden = false;
      montarFicha({
        carregar: () => (pers.ficha && Object.keys(pers.ficha).length ? pers.ficha : null),
        salvar: () => {},
        readOnly: true, budgetLocked: true, budgetValor,
      });
    } else {
      document.getElementById('somente-leitura')!.hidden = false;
    }

    // editor de XP: aparece sempre que o espectador é o mestre da mesa (inclusive no próprio personagem)
    if (ehMestre) {
      document.getElementById('mestre-xp')!.hidden = false;
      const xpInput = document.getElementById('xp-input') as HTMLInputElement;
      xpInput.value = String(budgetValor ?? 0);
      document.getElementById('xp-salvar')!.addEventListener('click', async () => {
        const xp = Math.max(0, +xpInput.value || 0);
        const { error } = await sb.from('personagem_xp').upsert(
          { personagem_id: id, xp, definido_por: user.id, atualizado_em: new Date().toISOString() },
          { onConflict: 'personagem_id' },
        );
        const st = document.getElementById('xp-salvo')!;
        if (error) { st.textContent = 'Erro: ' + error.message; st.style.color = '#b3261e'; return; }
        st.textContent = 'XP salvo (recarregando…)'; st.style.color = '';
        setTimeout(() => location.reload(), 700);
      });
    }
  }

  async function mostrarRetrato(sb: any, path: string) {
    const { data } = await sb.storage.from(BUCKET).createSignedUrl(path, 3600);
    if (!data?.signedUrl) return;
    const img = document.getElementById('retrato-img') as HTMLImageElement;
    img.src = data.signedUrl; img.hidden = false;
    document.getElementById('retrato-vazio')!.hidden = true;
  }
  async function subirRetrato(sb: any, id: string, file?: File) {
    if (!file) return;
    const ext = (file.name.split('.').pop() || 'jpg').toLowerCase();
    const path = `${id}/retrato-${Date.now()}.${ext}`;
    const { error } = await sb.storage.from(BUCKET).upload(path, file, { upsert: true, contentType: file.type });
    if (error) return alert('Erro ao enviar imagem: ' + error.message);
    await sb.from('personagens').update({ imagem_path: path }).eq('id', id);
    await mostrarRetrato(sb, path);
  }

  async function subirArquivo(sb: any, id: string, mesaId: string | null, userId: string, file?: File) {
    if (!file) return;
    const nomeSeguro = file.name.replace(/[^\w.\-]+/g, '_');
    const path = `${id}/anexo-${Date.now()}-${nomeSeguro}`;
    const { error } = await sb.storage.from(BUCKET).upload(path, file, { contentType: file.type });
    if (error) return alert('Erro ao enviar arquivo: ' + error.message);
    const { error: e2 } = await sb.from('arquivos').insert({
      mesa_id: mesaId, personagem_id: id, dono_id: userId, nome: file.name,
      storage_path: path, bucket: BUCKET, tipo: file.type, categoria: 'anexo-jogador',
    });
    if (e2) return alert('Enviado, mas erro ao registrar: ' + e2.message);
    await listarArquivos(sb, id, true);
  }
  async function listarArquivos(sb: any, id: string, ehDono: boolean) {
    const { data, error } = await sb.from('arquivos').select('*').eq('personagem_id', id).order('criado_em', { ascending: false });
    const ul = document.getElementById('arqs')!;
    if (error) { ul.innerHTML = `<li class="erro">${esc(error.message)}</li>`; return; }
    if (!data?.length) { ul.innerHTML = '<li class="muted">Nenhum arquivo ainda.</li>'; return; }
    ul.innerHTML = data.map((a: any) => `<li data-arq="${a.id}" data-path="${esc(a.storage_path)}" data-bucket="${esc(a.bucket || BUCKET)}">
      <a href="#" class="arq-abrir">${esc(a.nome)}</a>
      <span class="muted arq-tipo">${esc((a.tipo || '').split('/')[1] || '')}</span>
      ${ehDono ? '<button class="btn arq-rm" title="Remover">✕</button>' : ''}
    </li>`).join('');
    ul.querySelectorAll<HTMLElement>('.arq-abrir').forEach((a) => a.addEventListener('click', async (e) => {
      e.preventDefault();
      const li = a.closest('li')!; const { data: s } = await sb.storage.from(li.dataset.bucket!).createSignedUrl(li.dataset.path!, 3600);
      if (s?.signedUrl) window.open(s.signedUrl, '_blank');
    }));
    ul.querySelectorAll<HTMLElement>('.arq-rm').forEach((b) => b.addEventListener('click', async () => {
      const li = b.closest('li')!;
      if (!confirm('Remover este arquivo?')) return;
      await sb.storage.from(li.dataset.bucket!).remove([li.dataset.path!]);
      await sb.from('arquivos').delete().eq('id', li.dataset.arq);
      await listarArquivos(sb, id, true);
    }));
  }

  main();
</script>

<!-- is:global: cabeçalho, listas e ficha são preenchidos via JS -->
<style is:global>
  .voltar { margin: 0 0 .6rem; }
  .voltar a { color: var(--accent); text-decoration: none; }
  .pers-cab { display: flex; gap: 1.2rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 1rem; }
  .retrato { display: flex; flex-direction: column; gap: .5rem; align-items: center; }
  .retrato img { width: 160px; height: 160px; object-fit: cover; border-radius: 10px; border: 1px solid var(--rule); }
  .retrato-vazio { width: 160px; height: 160px; display: flex; align-items: center; justify-content: center; border: 1px dashed var(--rule); border-radius: 10px; color: var(--muted); font-size: .85rem; }
  .retrato-btn { cursor: pointer; font-size: .8rem; }
  .pers-tit h1 { margin: .1rem 0; }
  .xp-nota { color: var(--muted); font-size: .9rem; }
  .mestre-xp { display: flex; align-items: flex-end; gap: .6rem; flex-wrap: wrap; margin-top: .6rem; }
  .mestre-xp label { display: flex; flex-direction: column; font-family: 'Cinzel'; font-size: .7rem; text-transform: uppercase; letter-spacing: .04em; color: var(--ink-soft); gap: .2rem; }
  .mestre-xp input { width: 7rem; padding: .4rem; border: 1px solid var(--rule); border-radius: 6px; background: var(--bg); color: var(--ink); font: inherit; }
  .bloco { margin-top: 1.6rem; }
  .textos { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 760px) { .textos { grid-template-columns: 1fr; } }
  .textos label { display: flex; flex-direction: column; font-family: 'Cinzel'; font-size: .72rem; letter-spacing: .04em; color: var(--ink-soft); text-transform: uppercase; gap: .3rem; }
  .textos textarea { font: inherit; font-family: 'EB Garamond'; text-transform: none; letter-spacing: 0; padding: .6rem; border: 1px solid var(--rule); border-radius: 6px; background: var(--bg); color: var(--ink); resize: vertical; }
  .salvo { color: var(--accent); font-size: .8rem; }
  .arqs { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .3rem; margin-top: .6rem; }
  .arqs li { display: flex; align-items: center; gap: .6rem; padding: .35rem 0; border-bottom: 1px solid var(--rule); }
  .arqs .arq-abrir { flex: 1; color: var(--accent); text-decoration: none; }
  .arqs .arq-tipo { font-size: .78rem; text-transform: uppercase; }
  .arqs .arq-rm { background: none; border: none; color: #b3261e; cursor: pointer; }
  .aviso { border: 1px solid var(--gold, var(--rule)); border-radius: 8px; padding: 1rem; background: color-mix(in srgb, var(--gold, #caa) 12%, transparent); max-width: 46rem; margin-bottom: 1rem; }
  .erro { color: #b3261e; }
</style>
