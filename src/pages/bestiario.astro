---
import Base from '../layouts/Base.astro';
import { url } from '../lib/site';
import { loadData } from '../lib/data';
import monsters from '../data/monsters.json';
const d = await loadData();
// Fonte ÚNICA da página: monsters.json (gerado por scripts/gen-monsters.mjs a partir dos arquivos-fonte).
const inimigos = ([...monsters] as any[]).sort((a, b) => a.nome.localeCompare(b.nome, 'pt'));
const TIPO: Record<string, string> = { capanga: 'Capanga', soldado: 'Soldado', elite: 'Elite', fera: 'Fera', chefe: 'Chefe' };
// Ecologia (tipo PF2e · terreno · clima) → rótulos em português
const ECO_TIPO: Record<string, string> = { Aberration: 'Aberração', Animal: 'Animal', Astral: 'Astral', Beast: 'Besta', Celestial: 'Celestial', Construct: 'Construto', Dragon: 'Dragão', Dream: 'Onírico', Elemental: 'Elemental', Ethereal: 'Etéreo', Fey: 'Fada', Fiend: 'Corruptor', Fungus: 'Fungo', Giant: 'Gigante', Humanoid: 'Humanoide', Monitor: 'Monitor', Negative: 'Negativo', Ooze: 'Limo', Petitioner: 'Suplicante', Plant: 'Planta', Positive: 'Positivo', Shadow: 'Sombra', Spirit: 'Espírito', Time: 'Tempo', Undead: 'Morto-vivo' };
const ECO_TERR: Record<string, string> = { Cold: 'Gélido', Desert: 'Deserto', Forest: 'Floresta', Jungle: 'Selva', Mountain: 'Montanha', Plains: 'Planície', Swamp: 'Pântano', Underground: 'Subterrâneo', Urban: 'Urbano', Water: 'Aquático', Coast: 'Litoral', Sky: 'Céu', Ruins: 'Ruínas', Any: 'Qualquer' };
const ECO_CLIMA: Record<string, string> = { Cold: 'Frio', Temperate: 'Temperado', Tropical: 'Tropical', Extraplanar: 'Extraplanar' };
// Selos do Pathfinder disponíveis (public/icones-bestiario). Sem selo → cai no disco colorido.
const ICO_TIPO = new Set(['Dragon', 'Undead', 'Ooze', 'Plant', 'Fiend', 'Animal', 'Beast', 'Humanoid', 'Giant']);
const ICO_TERR = new Set(['Mountain', 'Forest', 'Plains', 'Swamp', 'Water', 'Coast', 'Urban', 'Underground', 'Ruins', 'Sky', 'Cold']);
const styTipo = (t: string) => (ICO_TIPO.has(t) ? `background-image:url(${url(`icones-bestiario/tipo-${t}.png`)})` : '');
const styTerr = (t: string) => (ICO_TERR.has(t) ? `background-image:url(${url(`icones-bestiario/terr-${t}.png`)})` : '');
// Atributos (ordem canônica: físico · social · mental) com rótulo curto e nome cheio
const ATR: [string, string, string][] = [
  ['forca', 'For', 'Força'], ['destreza', 'Des', 'Destreza'], ['vigor', 'Vig', 'Vigor'],
  ['influencia', 'Inf', 'Influência'], ['perspicacia', 'Psp', 'Perspicácia'], ['compostura', 'Cmp', 'Compostura'],
  ['percepcao', 'Per', 'Percepção'], ['inteligencia', 'Int', 'Inteligência'], ['raciocinio', 'Rac', 'Raciocínio'],
];
const arteNome: Record<string, string> = Object.fromEntries(d.artes.map((a) => [a.id, a.nome]));
const camNome: Record<string, string> = Object.fromEntries(d.caminhos.map((c) => [c.id, c.nome]));
const tecLink = (id: string) => url(`caminhos/${d.T[id]?.caminho?.id ?? ''}`) + '#' + id;

// listas de poderes por criatura (ids p/ filtro)
const caminhosDe = (i: any) => [...new Set((i.poderes || []).filter((p: any) => p.tipo === 'proeza' && p.caminho).map((p: any) => p.caminho))];
const artesDe = (i: any) => [...new Set((i.poderes || []).filter((p: any) => p.tipo === 'feiticaria' && p.arte).map((p: any) => p.arte))];

const caminhosUsados = [...new Set(inimigos.flatMap(caminhosDe))].map((id) => ({ id, nome: camNome[id] || id })).sort((a, b) => a.nome.localeCompare(b.nome));
const artesUsadas = [...new Set(inimigos.flatMap(artesDe))].map((id) => ({ id, nome: arteNome[id] || id })).sort((a, b) => a.nome.localeCompare(b.nome));
// Listas de filtro construídas DINAMICAMENTE do JSON (categoria · terreno · clima). Novo valor no dado → novo no filtro.
const categoriasUsadas = [...new Set(inimigos.map((i) => i.categoria).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'pt'));
const terrenosUsados = [...new Set(inimigos.flatMap((i) => i.ecologia?.terreno || []))].map((k) => ({ k, nome: ECO_TERR[k] || k })).sort((a, b) => a.nome.localeCompare(b.nome));
const climasUsados = [...new Set(inimigos.flatMap((i) => i.ecologia?.clima || []))].map((k) => ({ k, nome: ECO_CLIMA[k] || k })).sort((a, b) => a.nome.localeCompare(b.nome));
// Linha de ecologia (texto puro, separada por ·): categoria · terrenos · climas
const ecoLinha = (i: any) => [i.categoria, ...(i.ecologia?.terreno || []).map((t: string) => ECO_TERR[t] || t), ...(i.ecologia?.clima || []).map((c: string) => ECO_CLIMA[c] || c)].filter(Boolean).join(' · ');
const stars = (n: number) => '◆'.repeat(n) + '◇'.repeat(6 - n);
const cap = (s: string) => (s ? s.charAt(0).toUpperCase() + s.slice(1) : s);
// conceito sem o porte repetido (o Porte já aparece à parte), com inicial maiúscula
const conceitoLimpo = (i: any) => cap(String(i.conceito || '').replace(new RegExp(`\\s*\\b${i.porte}\\b\\s*`, 'i'), ' ').replace(/\s+/g, ' ').trim());
// ataque: "7d6+2 +8" → "7d6 +2 +8"; dano: tipo por extenso → sigla (I)/(C)/(P)/(Pr)
const DANO_AB: Record<string, string> = { impacto: '(I)', corte: '(C)', perfConc: '(P)', projetil: '(Pr)' };
const fmtPool = (s: string) => String(s || '').replace(/(\d+d6)\+/, '$1 +');
const fmtDano = (s: string) => String(s || '').replace(/\b(impacto|corte|perfConc|projetil)\b/g, (m) => DANO_AB[m]);
// tem conteúdo mecânico (Habilidades / Poderes / Técnicas / Artes / Notas) → botão do card flutuante
const temMec = (i: any) => !!((i.habilidades?.length) || (i.poderes?.length) || (i.tecnicas?.length) || (i.artes?.length) || i.notas);
---
<Base title="Bestiário & NPCs" largura="wide" descricao="Adversários prontos para o Mestre — do goblin ao dragão ancião, com blocos de combate calculados, arte de referência e poderes traduzidos em Proezas e Feitiçarias.">
  <h1>Bestiário & NPCs</h1>
  <p class="lead">Adversários prontos para a mesa, do camponês ao dragão ancião. Os números seguem as mesmas fórmulas dos personagens (PV, Defesa, Absorção, Iniciativa e pools de ataque já calculados), e os poderes especiais vêm traduzidos em <strong>Proezas</strong> (Técnicas de Caminho) e <strong>Feitiçarias</strong> (Artes).</p>

  <div class="callout regra"><span class="lbl">Informações</span>O bloco traz o <strong>Ataque</strong> (o pool, já com o Acerto) e o <strong>Dano</strong> prontos para rolar. O tipo de dano vem em sigla: <strong>Impacto (I)</strong>, <strong>Corte (C)</strong>, <strong>Perfuração (P)</strong>. <strong>Ameaça</strong> (◆) é uma referência rápida de perigo, de 1 a 6. Criaturas com <strong>Centelha</strong> usam <strong>Proezas</strong>, <strong>Feitiçaria</strong> ou alguma técnica equivalente. A lista de <strong>Poderes</strong> indica o Caminho ou Arte que reproduz cada efeito. Toque na arte para ampliar.</div>

  <div class="callout"><span class="lbl">Dano</span>O golpe de uma criatura soma a <strong>Força uma vez</strong> ao dano (um só membro: garra, presa, braço ou tentáculo). A Força só entra <strong>em dobro</strong> quando se empunha uma <strong>arma</strong> com mais de um membro (as duas mãos num montante, por exemplo), então os ataques naturais do bestiário usam sempre <strong>uma vez a Força</strong>. Uma criatura com muitos membros ataca <strong>várias vezes</strong> (um golpe por membro), não com mais Força por golpe.</div>

  <div class="callout"><span class="lbl">Valores médios</span>Atributos, Habilidades, Proezas e dimensões (tamanho e peso) são a <strong>média da espécie</strong>: um indivíduo pode ser maior, mais forte ou mais fraco. Ajuste à vontade para dar cara a um chefe nomeado ou a um espécime fora da curva. Os números derivados (PV, Defesa, Absorção, Iniciativa) seguem as mesmas fórmulas dos personagens.</div>

  <div class="callout"><span class="lbl">Regra de Horda</span>Muitos capangas iguais lutam como um <strong>esquadrão único</strong>: o tamanho vira <strong>Magnitude</strong> (2–3 = +1d6, 4–7 = +2, 8–15 = +3…), somada ao <strong>acerto e ao dano</strong>; a Defesa cai <strong>−2</strong> (aglomerado). <a href={url('regras/combate') + '#regra-de-horda'}>Regra completa →</a></div>

  <div class="filtros panel">
    <label class="busca">Buscar <input type="search" data-bf="q" placeholder="nome, conceito, efeito…" /></label>
    <label class="ord">Ordenar por
      <span class="ord-row">
        <select id="ord-key">
          <option value="nome">Nome (A→Z)</option>
          <option value="en">Nome em inglês</option>
          <option value="pv">PV</option>
          <option value="defesa">Defesa</option>
          <option value="centelha">Centelha</option>
          <option value="ameaca">Ameaça</option>
        </select>
        <button type="button" id="ord-dir" title="Inverter ordem" aria-label="Inverter ordem"><span class="ord-arw">↑</span></button>
      </span>
    </label>
    {/* Proeza (Caminho) e Feitiçaria (Arte) ocultos por ora — trocar false por true reativa */}
    {false && (
      <>
        <label>Proeza (Caminho)
          <select data-bf="proeza">
            <option value="">qualquer Caminho</option>
            {caminhosUsados.map((c) => <option value={c.id}>{c.nome}</option>)}
          </select>
        </label>
        <label>Feitiçaria (Arte)
          <select data-bf="feiticaria">
            <option value="">qualquer Arte</option>
            {artesUsadas.map((a) => <option value={a.id}>{a.nome}</option>)}
          </select>
        </label>
      </>
    )}
    <fieldset class="cats"><legend>Tipo de criatura</legend>{categoriasUsadas.map((c) => <label class="chk"><input type="checkbox" data-bf="tipo" value={c} />{c}</label>)}</fieldset>
    <fieldset class="cats"><legend>Terreno</legend>{terrenosUsados.map((t) => <label class="chk"><input type="checkbox" data-bf="terreno" value={t.k} />{t.nome}</label>)}</fieldset>
    <fieldset class="cats"><legend>Clima</legend>{climasUsados.map((c) => <label class="chk"><input type="checkbox" data-bf="clima" value={c.k} />{c.nome}</label>)}</fieldset>
    <p class="muted bf-count"></p>
  </div>

  <div class="besta-list">
    {inimigos.map((i) => (
      <article class="besta" id={i.id} data-permalink data-categoria={i.categoria || 'Outro'}
        data-tipo={i.categoria || ''} data-terreno={(i.ecologia?.terreno || []).join(' ')} data-clima={(i.ecologia?.clima || []).join(' ')}
        data-caminhos={caminhosDe(i).join(' ')} data-artes={artesDe(i).join(' ')}
        data-nome={i.nome} data-en={i.nomeIngles || i.nome} data-pv={i.combate.pv} data-defesa={i.combate.defesa} data-centelha={i.centelha} data-ameaca={i.ameaca}
        data-txt={(i.nome + ' ' + (i.nomeIngles || '') + ' ' + i.conceito + ' ' + (i.categoria || '') + ' ' + i.tags.join(' ') + ' ' + (i.habilidades || []).map((h: any) => h.nome + ' ' + h.descricao).join(' ') + ' ' + (i.poderes || []).map((p: any) => p.efeito + ' ' + p.alvo).join(' ')).toLowerCase()}>

        <figure class={`arte${i.imagem ? '' : ' sem-arte'}`} data-cent={i.centelha}>
          {i.imagem
            ? <img src={url(i.imagem)} alt={`Ilustração de ${i.nome}`} loading="lazy" decoding="async"
                   data-full={url(i.imagem)} data-nome={i.nome} />
            : <span class="capitular cinzel" aria-hidden="true">{i.nome.trim()[0]}</span>}
          <span class="arte-ameaca" title={`Ameaça ${i.ameaca}/6`}>{stars(i.ameaca)}</span>
          {i.centelha > 0 && <span class="arte-cent" title={`Centelha ${i.centelha}`}>✦ {i.centelha}</span>}
        </figure>

        <div class="besta-corpo">
          <header class="besta-head">
            <span class="besta-nome cinzel">{i.nome}</span>
          </header>
          <div class="besta-badges">
            {i.categoria && <span class="badge cat">{i.categoria}</span>}
            {(i.ecologia?.terreno || []).map((t: string) => <span class="badge terr">{ECO_TERR[t] || t}</span>)}
            {(i.ecologia?.clima || []).map((c: string) => <span class="badge clima">{ECO_CLIMA[c] || c}</span>)}
          </div>
          {i.porte && (
            <p class="besta-porte"><span class="pt-lbl">Porte</span><span class="pt-cat">{i.porte}</span><span class="pt-sep">·</span>{i.dimensoes.medida}<span class="pt-sep">·</span>{i.dimensoes.peso}</p>
          )}

          {i.descricao && <p class="besta-con muted">{i.descricao}</p>}

          <dl class="besta-stats">
            <div><dt>PV</dt><dd>{i.combate.pv}</dd></div>
            <div><dt>Defesa</dt><dd>{i.combate.defesa}</dd></div>
            <div><dt>Def. Mental</dt><dd>{i.combate.defesaMental}</dd></div>
            <div><dt>Absorção</dt><dd>{i.combate.absorcao.impacto}/{i.combate.absorcao.corte}/{i.combate.absorcao.perfuracao}{i.combate.resistenciaPerfuracao ? `·N${i.combate.resistenciaPerfuracao}` : ''}</dd></div>
            <div><dt>Iniciativa</dt><dd>{i.combate.iniciativa}</dd></div>
          </dl>

          {i.atributos && (
            <div class="besta-atrib">
              <span class="atr-lbl">Atributos</span>
              <div class="atr-grid">
                {ATR.map(([k, ab, full]) => (
                  <span class="atr" title={full}><span class="atr-nm"><span class="atr-ab">{ab}</span><span class="atr-full">{full}</span></span><span class="atr-v">{(i.atributos as any)[k]}</span></span>
                ))}
              </div>
            </div>
          )}

          <ul class="besta-atk">
            {i.combate.ataques.map((a: any) => (
              <li><span class="atk-nome">{a.nome}</span><span class="atk-rolls">Ataque: <b>{fmtPool(a.pool)}</b> · Dano <b>{fmtDano(a.dano)}</b> · Speed {a.speed}</span>{a.notas ? <span class="atk-nota muted">{a.notas}</span> : null}</li>
            ))}
          </ul>

          {(temMec(i) || i.lore?.length > 0) && (
            <div class="besta-foot">
              {temMec(i) && (
                <button class="besta-info besta-mech" type="button" aria-haspopup="dialog"><span class="i-ic" aria-hidden="true">☰</span> Habilidades &amp; Poderes</button>
              )}
              {i.lore?.length > 0 && (
                <button class="besta-info" type="button" aria-haspopup="dialog"><span class="i-ic" aria-hidden="true">ⓘ</span> Informações</button>
              )}

              {temMec(i) && (
                <template class="mech-tpl">
                  {i.habilidades?.length > 0 && (<>
                    <h4>Habilidades</h4>
                    <ul class="ib-hab">{i.habilidades.map((h: any) => (<li><b>{h.nome}</b> {h.descricao}</li>))}</ul>
                  </>)}
                  {i.poderes?.length > 0 && (<>
                    <h4>Poderes <span class="ib-sub-lbl">(sistema)</span></h4>
                    <ul class="ib-pod">{i.poderes.map((p: any) => (<li class={`pw-${p.tipo}`}><span class="pw-ef">{p.efeito}</span> <span class="pw-arw">→</span> <span class="pw-alvo">{p.alvo}</span></li>))}</ul>
                  </>)}
                  {(i.tecnicas.length > 0 || i.artes.length > 0 || i.notas) && (<>
                    <h4>Técnicas, Artes &amp; Notas</h4>
                    {i.tecnicas.length > 0 && (<p class="ib-ref"><b>Técnicas:</b> {i.tecnicas.map((t: any, n: number) => (<>{n > 0 && ' · '}<a href={tecLink(t)}>{d.T[t]?.nome ?? t}</a></>))}</p>)}
                    {i.artes.length > 0 && (<p class="ib-ref"><b>Artes:</b> {i.artes.map((a: any, n: number) => (<>{n > 0 && ' · '}<a href={url('arcano') + '#' + a.id}>{arteNome[a.id] ?? a.id}</a> {a.nivel}</>))}</p>)}
                    {i.notas && <p class="ib-notas">{i.notas}</p>}
                  </>)}
                </template>
              )}
              {i.lore?.length > 0 && (
                <template class="lore-tpl">{i.lore.map((s: any) => (<><h4>{s.titulo}</h4><p>{s.texto}</p></>))}</template>
              )}
            </div>
          )}
        </div>
      </article>
    ))}
  </div>

  <div class="lightbox" id="lightbox" hidden>
    <button class="lb-fechar" aria-label="Fechar">✕</button>
    <figure><img id="lb-img" src="" alt="" /><figcaption id="lb-cap" class="cinzel"></figcaption></figure>
  </div>

  <button id="ao-topo" class="ao-topo" aria-label="Voltar ao topo" title="Voltar ao topo" hidden>↑</button>

  <div class="infobox" id="infobox" hidden role="dialog" aria-modal="true" aria-labelledby="ib-nome">
    <div class="ib-card">
      <button class="ib-fechar" aria-label="Fechar">✕</button>
      <header class="ib-head">
        <img class="ib-art" id="ib-art" src="" alt="" />
        <div class="ib-head-txt">
          <h3 id="ib-nome" class="cinzel"></h3>
          <p class="ib-sub" id="ib-sub"></p>
        </div>
      </header>
      <div class="ib-body" id="ib-body"></div>
    </div>
  </div>
</Base>

<style>
  .filtros { margin: 1rem 0 1.4rem; display: flex; flex-wrap: wrap; gap: .8rem 1.2rem; align-items: flex-end; }
  .filtros > label { font-family: 'Cinzel'; font-size: .78rem; color: var(--ink-soft); display: flex; flex-direction: column; gap: .25rem; }
  .filtros input[type='search'], .filtros select { padding: .35rem .5rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); font-family: 'EB Garamond'; font-size: .95rem; }
  .filtros .busca input { min-width: 13rem; }
  .filtros select { min-width: 11rem; }
  .filtros fieldset { border: 1px solid var(--panel-border); border-radius: 5px; padding: .3rem .6rem; max-width: 100%; }
  .filtros legend { font-family: 'Cinzel'; font-size: .72rem; color: var(--ink-soft); }
  .cats { display: flex; flex-wrap: wrap; gap: .1rem .4rem; }
  .chk { display: inline-flex; align-items: center; gap: .25rem; margin-right: .4rem; font-family: 'EB Garamond'; font-size: .92rem; }
  .bf-count { width: 100%; margin: 0; }

  .ord-row { display: flex; gap: .3rem; align-items: stretch; }
  #ord-dir { padding: 0 .55rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--accent-strong); cursor: pointer; font-size: 1rem; line-height: 1; display: flex; align-items: center; transition: background .15s, border-color .15s; }
  #ord-dir:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, var(--bg)); }
  #ord-dir .ord-arw { font-weight: 700; }

  .besta-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr)); gap: 1.15rem; }

  /* --- Card como entrada de bestiário --- */
  .besta {
    display: flex; flex-direction: column;
    border: 1px solid var(--panel-border); border-radius: 9px; background: var(--panel);
    overflow: hidden; scroll-margin-top: 4rem;
    box-shadow: 0 1px 2px color-mix(in srgb, var(--ink) 8%, transparent);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
  }
  .besta:hover { transform: translateY(-3px); box-shadow: 0 10px 26px color-mix(in srgb, var(--ink) 16%, transparent); border-color: color-mix(in srgb, var(--accent) 40%, var(--panel-border)); }
  .besta:target { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent); }

  /* Placa de ilustração: fundo pergaminho fixo (claro nos dois temas) + multiply une PNG e JPG */
  .arte {
    position: relative; margin: 0; aspect-ratio: 4 / 3;
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(120% 90% at 50% 15%, #fbf6e7 0%, #efe4c9 62%, #e4d5b2 100%);
    border-bottom: 1px solid var(--panel-border);
    overflow: hidden; cursor: zoom-in;
  }
  .arte::after { /* vinheta impressa */
    content: ''; position: absolute; inset: 0; pointer-events: none;
    box-shadow: inset 0 0 2.4rem rgba(60, 42, 18, .22), inset 0 -1.2rem 1.6rem rgba(60, 42, 18, .1);
  }
  .arte img {
    width: 100%; height: 100%; object-fit: contain; padding: .5rem .6rem .2rem;
    mix-blend-mode: multiply; filter: saturate(1.02);
    transition: transform .35s ease;
  }
  .besta:hover .arte img { transform: scale(1.045); }
  .arte.sem-arte { cursor: default; }
  .capitular {
    font-size: 4.6rem; line-height: 1; color: color-mix(in srgb, var(--accent) 62%, #8a6a2f);
    text-shadow: 0 1px 0 #fff, 0 2px 4px rgba(90, 60, 20, .25); user-select: none;
  }
  .arte-ameaca {
    position: absolute; left: .55rem; bottom: .45rem; z-index: 2;
    color: var(--gold); letter-spacing: .08em; font-size: 1.23rem;
    text-shadow: 0 1px 2px rgba(0,0,0,.55); filter: drop-shadow(0 0 1px rgba(0,0,0,.4));
  }
  .arte-cent {
    position: absolute; left: .5rem; top: .5rem; z-index: 2;
    font-family: 'Cinzel'; font-size: 1.05rem; font-weight: 600; letter-spacing: .03em;
    padding: .18rem .68rem; border-radius: 999px;
    color: #fff; background: color-mix(in srgb, var(--accent-strong) 90%, #000);
    box-shadow: 0 2px 5px rgba(0,0,0,.4);
  }

  .besta-corpo { display: flex; flex-direction: column; padding: .7rem .9rem .85rem; }
  .besta-head { display: flex; flex-wrap: wrap; gap: .38rem; align-items: center; }
  .besta-nome { font-size: 1.12rem; color: var(--accent); line-height: 1.15; }
  .badge.cat { background: var(--accent-strong); color: var(--on-accent); }
  .besta-con { font-style: italic; margin: .3rem 0 .4rem; font-size: .9rem; }
  .besta-porte { display: flex; flex-wrap: wrap; align-items: baseline; gap: .35rem; margin: 0 0 .5rem; font-size: .84rem; color: var(--ink-soft); }
  .pt-lbl { font-family: 'Cinzel'; font-size: .62rem; text-transform: uppercase; letter-spacing: .04em; color: var(--accent-strong); }
  .pt-cat { font-family: 'Cinzel'; font-size: .74rem; color: var(--ink); }
  .pt-sep { color: color-mix(in srgb, var(--ink) 35%, transparent); }

  /* Badges numa linha abaixo do nome: terreno verde-terra, clima roxo (contraste) */
  .besta-badges { display: flex; flex-wrap: wrap; gap: .3rem; margin: .3rem 0 .1rem; }
  .badge.terr { background: color-mix(in srgb, #4b7a3f 20%, var(--panel-2)); color: var(--ink); border-color: color-mix(in srgb, #4b7a3f 38%, var(--panel-border)); }
  .badge.clima { background: color-mix(in srgb, #8a5bbf 24%, var(--panel-2)); color: var(--ink); border-color: color-mix(in srgb, #8a5bbf 44%, var(--panel-border)); }

  .besta-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(4.4rem, 1fr)); gap: .3rem; margin: 0 0 .55rem; padding: .5rem 0; border-top: 1px dotted var(--rule); border-bottom: 1px dotted var(--rule); }
  .besta-stats div { display: flex; flex-direction: column; align-items: center; text-align: center; gap: .05rem; }
  .besta-stats dt { font-family: 'Cinzel'; color: var(--accent-strong); font-size: .6rem; text-transform: uppercase; letter-spacing: .04em; }
  .besta-stats dd { margin: 0; font-size: 1rem; font-variant-numeric: tabular-nums; font-weight: 600; }

  /* Atributos */
  .besta-atrib { margin: 0 0 .55rem; }
  .atr-lbl { font-family: 'Cinzel'; font-size: .68rem; text-transform: uppercase; letter-spacing: .04em; color: var(--accent-strong); }
  /* colunas: Físico | Social | Mental (ordem de coluna, não de linha) */
  .atr-grid { display: grid; grid-template-rows: repeat(3, auto); grid-auto-flow: column; gap: .2rem .4rem; margin-top: .3rem; }
  .atr { display: flex; align-items: baseline; justify-content: space-between; gap: .3rem; padding: .1rem .4rem; border-radius: 4px; background: color-mix(in srgb, var(--accent) 6%, transparent); }
  .atr-nm { font-family: 'Cinzel'; font-size: .68rem; color: var(--ink-soft); min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .atr-ab { text-transform: uppercase; letter-spacing: .02em; }
  .atr-full { display: none; font-size: .64rem; letter-spacing: 0; }
  .atr-v { font-variant-numeric: tabular-nums; font-weight: 700; font-size: .95rem; color: var(--accent-strong); }
  /* nome por extenso em telas maiores */
  @media (min-width: 720px) {
    .atr-ab { display: none; }
    .atr-full { display: inline; }
  }

  /* Habilidades */
  .besta-atk { list-style: none; padding: 0; margin: 0 0 .5rem; font-size: .9rem; display: flex; flex-direction: column; gap: .3rem; }
  .besta-atk li { display: flex; flex-direction: column; gap: .05rem; padding-left: .7rem; border-left: 2px solid color-mix(in srgb, var(--accent) 45%, transparent); }
  .atk-nome { font-family: 'Cinzel'; font-size: .82rem; color: var(--ink); }
  .atk-rolls b { color: var(--accent-strong); }
  .atk-nota { font-size: .82rem; font-style: italic; }

  .besta-foot { margin-top: auto; padding-top: .6rem; display: flex; flex-wrap: wrap; gap: .5rem; }
  .besta-info {
    flex: 1 1 8rem; display: inline-flex; align-items: center; gap: .35rem; justify-content: center;
    padding: .4rem .6rem; border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--panel-border));
    border-radius: 6px; background: color-mix(in srgb, var(--accent) 7%, transparent);
    color: var(--accent-strong); font-family: 'Cinzel'; font-size: .72rem; letter-spacing: .02em;
    cursor: pointer; transition: background .15s, border-color .15s;
  }
  .besta-mech { background: color-mix(in srgb, var(--gold) 12%, transparent); border-color: color-mix(in srgb, var(--gold) 45%, var(--panel-border)); color: var(--ink); }
  .besta-mech:hover { background: color-mix(in srgb, var(--gold) 24%, transparent); border-color: var(--gold); }
  .besta-info:hover { background: color-mix(in srgb, var(--accent) 16%, transparent); border-color: var(--accent); }
  .besta-info .i-ic { font-size: .95rem; line-height: 1; }
  .lore-tpl { display: none; }

  /* --- Lightbox --- */
  .lightbox { position: fixed; inset: 0; z-index: 90; display: flex; align-items: center; justify-content: center; padding: 1.5rem; background: color-mix(in srgb, #1a120a 82%, transparent); backdrop-filter: blur(3px); animation: lb-in .18s ease; }
  .lightbox[hidden] { display: none; }
  .lightbox figure { margin: 0; max-width: min(680px, 92vw); max-height: 88vh; display: flex; flex-direction: column; align-items: center; gap: .6rem; }
  .lightbox img { max-width: 100%; max-height: 78vh; object-fit: contain; background: radial-gradient(120% 90% at 50% 15%, #fbf6e7, #e4d5b2); border-radius: 8px; padding: 1rem; box-shadow: 0 18px 50px rgba(0,0,0,.5); }
  .lb-cap, #lb-cap { color: #f3e8cf; font-size: 1.25rem; letter-spacing: .02em; }
  .lb-fechar { position: absolute; top: 1rem; right: 1.2rem; width: 2.4rem; height: 2.4rem; border-radius: 50%; border: none; background: rgba(255,255,255,.12); color: #fff; font-size: 1.2rem; cursor: pointer; transition: background .15s; }
  .lb-fechar:hover { background: rgba(255,255,255,.25); }
  @keyframes lb-in { from { opacity: 0; } to { opacity: 1; } }

  /* Voltar ao topo */
  .ao-topo {
    position: fixed; right: 1.1rem; bottom: 1.1rem; z-index: 60;
    width: 2.9rem; height: 2.9rem; border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--panel-border));
    background: var(--accent-strong); color: var(--on-accent);
    font-size: 1.3rem; line-height: 1; cursor: pointer;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--ink) 28%, transparent);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: translateY(8px); transition: opacity .2s ease, transform .2s ease, background .15s;
  }
  .ao-topo.show { opacity: 1; transform: translateY(0); }
  .ao-topo:hover { background: var(--accent); }
  .ao-topo[hidden] { display: none; }

  @media (prefers-reduced-motion: reduce) { .besta, .arte img, .lightbox, .ao-topo { transition: none; animation: none; } .besta:hover { transform: none; } .besta:hover .arte img { transform: none; } }
</style>

<style is:global>
  /* Card flutuante de informações (conteúdo criado via JS → is:global) */
  .infobox { position: fixed; inset: 0; z-index: 95; display: flex; align-items: center; justify-content: center; padding: 1.2rem; background: color-mix(in srgb, #1a120a 78%, transparent); backdrop-filter: blur(3px); animation: ib-fade .18s ease; }
  .infobox[hidden] { display: none; }
  .infobox .ib-card {
    position: relative; width: min(560px, 94vw); max-height: 88vh; overflow-y: auto;
    background: var(--panel); color: var(--ink);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, var(--panel-border));
    border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,.5);
    padding: 1.3rem 1.4rem 1.5rem;
  }
  .infobox .ib-fechar { position: absolute; top: .6rem; right: .6rem; width: 2rem; height: 2rem; border-radius: 50%; border: none; background: color-mix(in srgb, var(--ink) 10%, transparent); color: var(--ink); font-size: 1rem; cursor: pointer; transition: background .15s; }
  .infobox .ib-fechar:hover { background: color-mix(in srgb, var(--ink) 22%, transparent); }
  .infobox .ib-head { display: flex; gap: .9rem; align-items: center; margin-bottom: .9rem; padding-right: 1.6rem; border-bottom: 1px dotted var(--rule); padding-bottom: .8rem; }
  .infobox .ib-art { width: 84px; height: 84px; object-fit: contain; border-radius: 8px; padding: .3rem; flex: 0 0 auto; background: radial-gradient(120% 90% at 50% 15%, #fbf6e7, #e4d5b2); mix-blend-mode: multiply; }
  .infobox .ib-art[hidden] { display: none; }
  .infobox .ib-head-txt { min-width: 0; }
  .infobox #ib-nome { margin: 0; font-size: 1.5rem; color: var(--accent); line-height: 1.1; }
  .infobox .ib-sub { margin: .25rem 0 0; font-size: .82rem; color: var(--ink-soft); font-style: italic; }
  .infobox .ib-body h4 { font-family: 'Cinzel'; font-size: .82rem; letter-spacing: .02em; color: var(--accent-strong); margin: .95rem 0 .2rem; }
  .infobox .ib-body h4:first-child { margin-top: 0; }
  .infobox .ib-body p { margin: .2rem 0 0; font-size: .96rem; line-height: 1.5; color: var(--ink); }
  .infobox .ib-sub-lbl { font-family: 'EB Garamond'; text-transform: none; letter-spacing: 0; color: var(--ink-soft); font-size: .78rem; }
  /* Habilidades / Poderes / Técnicas dentro do card flutuante */
  .infobox .ib-hab { list-style: none; padding: 0; margin: .35rem 0 0; font-size: .92rem; display: flex; flex-direction: column; gap: .32rem; }
  .infobox .ib-hab li { padding-left: .7rem; border-left: 2px solid color-mix(in srgb, var(--gold) 55%, transparent); line-height: 1.4; color: var(--ink-soft); }
  .infobox .ib-hab li b { font-family: 'Cinzel'; font-size: .84rem; font-weight: 600; color: var(--ink); }
  .infobox .ib-hab li b::after { content: ': '; color: var(--ink-soft); font-family: 'EB Garamond'; font-weight: 400; }
  .infobox .ib-pod { list-style: none; padding: 0; margin: .35rem 0 0; font-size: .9rem; display: flex; flex-direction: column; gap: .22rem; }
  .infobox .ib-pod li { display: flex; flex-wrap: wrap; align-items: baseline; gap: .3rem; }
  .infobox .ib-pod .pw-arw { color: var(--ink-soft); }
  .infobox .ib-pod .pw-alvo { font-weight: 600; padding: .05rem .5rem; border-radius: 10px; font-size: .82rem; }
  .infobox .ib-pod .pw-proeza .pw-alvo, .infobox .pw-proeza .pw-alvo { background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--accent-strong); }
  .infobox .pw-feiticaria .pw-alvo { background: color-mix(in srgb, var(--gold) 26%, transparent); color: var(--ink); }
  .infobox .pw-natural .pw-alvo { background: var(--bg-soft); color: var(--ink-soft); font-weight: 500; }
  .infobox .ib-ref { font-size: .92rem; margin: .3rem 0 0; }
  .infobox .ib-ref b { font-family: 'Cinzel'; font-size: .74rem; color: var(--accent-strong); }
  .infobox .ib-notas { font-size: .88rem; color: var(--ink-soft); font-style: italic; margin: .4rem 0 0; }
  .infobox .ib-body a { color: var(--accent-strong); }
  @keyframes ib-fade { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .infobox { animation: none; } }
</style>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.besta'));
  const count = document.querySelector<HTMLElement>('.bf-count')!;
  const val = (s: string) => (document.querySelector(`[data-bf="${s}"]`) as HTMLInputElement | HTMLSelectElement)?.value.trim().toLowerCase() ?? '';
  const checked = (s: string) => Array.from(document.querySelectorAll<HTMLInputElement>(`[data-bf="${s}"]:checked`)).map((c) => c.value);
  function apply() {
    const text = val('q'), proeza = val('proeza'), feit = val('feiticaria');
    const tipos = checked('tipo'), terrs = checked('terreno'), climas = checked('clima');
    let n = 0;
    for (const c of cards) {
      const caminhos = (c.dataset.caminhos || '').split(' ').filter(Boolean);
      const artes = (c.dataset.artes || '').split(' ').filter(Boolean);
      const cTerr = (c.dataset.terreno || '').split(' ').filter(Boolean);
      const cClima = (c.dataset.clima || '').split(' ').filter(Boolean);
      const ok = (!tipos.length || tipos.includes(c.dataset.tipo!)) &&
        (!terrs.length || terrs.some((t) => cTerr.includes(t))) &&
        (!climas.length || climas.some((t) => cClima.includes(t))) &&
        (!proeza || caminhos.includes(proeza)) &&
        (!feit || artes.includes(feit)) &&
        (!text || c.dataset.txt!.includes(text));
      c.style.display = ok ? '' : 'none'; if (ok) n++;
    }
    count.textContent = `${n} adversário${n === 1 ? '' : 's'}`;
  }
  document.querySelectorAll('[data-bf]').forEach((e) => { e.addEventListener('input', apply); e.addEventListener('change', apply); });
  apply();

  // Ordenação (complementar: desempate sempre por nome A→Z)
  const list = document.querySelector<HTMLElement>('.besta-list')!;
  const ordKey = document.getElementById('ord-key') as HTMLSelectElement;
  const ordDir = document.getElementById('ord-dir') as HTMLButtonElement;
  const ordArw = ordDir.querySelector('.ord-arw') as HTMLElement;
  const NUM = ['pv', 'defesa', 'centelha', 'ameaca'];
  let dir = 1; // 1 = crescente, -1 = decrescente
  const coll = new Intl.Collator('pt', { sensitivity: 'base' });
  function sortCards() {
    const key = ordKey.value;
    const num = NUM.includes(key);
    cards.sort((a, b) => {
      let cmp = num
        ? (parseFloat(a.dataset[key] || '0') - parseFloat(b.dataset[key] || '0'))
        : coll.compare(a.dataset[key] || '', b.dataset[key] || '');
      cmp *= dir;
      return cmp || coll.compare(a.dataset.nome || '', b.dataset.nome || '');
    });
    const frag = document.createDocumentFragment();
    for (const c of cards) frag.appendChild(c);
    list.appendChild(frag);
  }
  function setArrow() { ordArw.textContent = dir === 1 ? '↑' : '↓'; }
  ordKey.addEventListener('change', () => { dir = NUM.includes(ordKey.value) ? -1 : 1; setArrow(); sortCards(); });
  ordDir.addEventListener('click', () => { dir = -dir; setArrow(); sortCards(); });
  setArrow(); sortCards();

  // Voltar ao topo
  const topBtn = document.getElementById('ao-topo') as HTMLButtonElement;
  const onScroll = () => {
    const show = window.scrollY > 600;
    if (show) { topBtn.hidden = false; requestAnimationFrame(() => topBtn.classList.add('show')); }
    else { topBtn.classList.remove('show'); }
  };
  topBtn.addEventListener('transitionend', () => { if (!topBtn.classList.contains('show')) topBtn.hidden = true; });
  topBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Lightbox da arte
  const lb = document.getElementById('lightbox') as HTMLElement;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCap = document.getElementById('lb-cap') as HTMLElement;
  function abrir(src: string, nome: string) { lbImg.src = src; lbImg.alt = `Ilustração de ${nome}`; lbCap.textContent = nome; lb.hidden = false; document.body.style.overflow = 'hidden'; }
  function fechar() { lb.hidden = true; lbImg.src = ''; document.body.style.overflow = ''; }
  document.querySelectorAll<HTMLImageElement>('.arte img[data-full]').forEach((im) => {
    im.addEventListener('click', () => abrir(im.dataset.full!, im.dataset.nome || ''));
  });
  lb.addEventListener('click', (e) => { if (e.target === lb || (e.target as HTMLElement).classList.contains('lb-fechar')) fechar(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !lb.hidden) fechar(); });

  // Card flutuante de informações (lore)
  const ib = document.getElementById('infobox') as HTMLElement;
  const ibNome = document.getElementById('ib-nome') as HTMLElement;
  const ibSub = document.getElementById('ib-sub') as HTMLElement;
  const ibArt = document.getElementById('ib-art') as HTMLImageElement;
  const ibBody = document.getElementById('ib-body') as HTMLElement;
  function abrirModal(card: HTMLElement, tplSel: string) {
    const tpl = card.querySelector<HTMLTemplateElement>(tplSel);
    ibBody.replaceChildren();
    if (tpl) ibBody.appendChild(tpl.content.cloneNode(true));
    ibNome.textContent = card.dataset.nome || '';
    const porte = card.querySelector('.besta-porte');
    const con = card.querySelector('.besta-con');
    const porteTxt = porte ? Array.from(porte.childNodes).map((n) => n.textContent).join(' ') : '';
    ibSub.textContent = (porteTxt || con?.textContent || '').replace(/\s*·\s*/g, ' · ').replace(/\s+/g, ' ').trim();
    const img = card.querySelector<HTMLImageElement>('.arte img[data-full]');
    if (img) { ibArt.src = img.src; ibArt.alt = ibNome.textContent || ''; ibArt.hidden = false; }
    else { ibArt.removeAttribute('src'); ibArt.hidden = true; }
    ib.hidden = false; document.body.style.overflow = 'hidden';
    (ib.querySelector('.ib-fechar') as HTMLElement)?.focus();
  }
  function fecharInfo() { ib.hidden = true; ibBody.replaceChildren(); document.body.style.overflow = ''; }
  document.querySelectorAll<HTMLButtonElement>('.besta-foot .besta-info').forEach((b) => {
    b.addEventListener('click', () => {
      const card = b.closest('.besta') as HTMLElement;
      if (card) abrirModal(card, b.classList.contains('besta-mech') ? '.mech-tpl' : '.lore-tpl');
    });
  });
  ib.addEventListener('click', (e) => { if (e.target === ib || (e.target as HTMLElement).classList.contains('ib-fechar')) fecharInfo(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !ib.hidden) fecharInfo(); });
</script>
