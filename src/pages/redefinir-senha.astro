---
import Base from '../layouts/Base.astro';
---
<Base title="Redefinir senha" descricao="Defina uma nova senha a partir do link do e-mail.">
  <h1>Redefinir senha</h1>

  <div id="setup" class="aviso" hidden>
    <strong>Área de contas ainda não configurada.</strong>
    <p class="muted">Falta ligar o Supabase. Veja <code>supabase/README.md</code>.</p>
  </div>

  <div id="checando" class="muted">Verificando o link…</div>

  <div id="invalido" class="aviso" hidden>
    <strong>Link inválido ou expirado.</strong>
    <p class="muted">Peça um novo link em <a id="link-entrar" href="#">Entrar → Esqueci a senha</a> (ou em Minha Conta).</p>
  </div>

  <form id="form" class="painel" hidden>
    <p class="muted">Defina sua nova senha.</p>
    <label>Nova senha (mín. 6)<input type="password" name="senha" minlength="6" autocomplete="new-password" required /></label>
    <label>Repetir a nova senha<input type="password" name="senha2" minlength="6" autocomplete="new-password" required /></label>
    <button class="btn primary" type="submit">Salvar nova senha</button>
    <span id="msg" class="msg" role="status" aria-live="polite"></span>
  </form>
</Base>

<script>
  import { getSupabase } from '../lib/supabase';
  import { supabaseConfigurado } from '../lib/auth';
  const base = import.meta.env.BASE_URL;

  if (!supabaseConfigurado) {
    document.getElementById('checando')!.hidden = true;
    document.getElementById('setup')!.hidden = false;
  } else {
    (document.getElementById('link-entrar') as HTMLAnchorElement).href = `${base.replace(/\/$/, '')}/entrar`;
    const sb = getSupabase();
    let pronto = false;
    const mostrarForm = () => {
      if (pronto) return; pronto = true;
      document.getElementById('checando')!.hidden = true;
      document.getElementById('invalido')!.hidden = true;
      document.getElementById('form')!.hidden = false;
    };
    const mostrarInvalido = () => {
      if (pronto) return;
      document.getElementById('checando')!.hidden = true;
      document.getElementById('invalido')!.hidden = false;
    };

    sb.auth.onAuthStateChange((event, session) => { if (session && (event === 'PASSWORD_RECOVERY' || event === 'SIGNED_IN')) mostrarForm(); });
    // fallback: o link já pode ter estabelecido a sessão de recuperação
    (async () => { const { data } = await sb.auth.getSession(); if (data.session) mostrarForm(); })();
    setTimeout(async () => { const { data } = await sb.auth.getSession(); if (data.session) mostrarForm(); else mostrarInvalido(); }, 2500);

    document.getElementById('form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const s1 = (f.senha as any).value, s2 = (f.senha2 as any).value;
      const msg = document.getElementById('msg')!;
      if (s1 !== s2) { msg.textContent = 'As senhas não conferem.'; msg.className = 'msg erro'; return; }
      msg.textContent = 'Salvando…'; msg.className = 'msg';
      const { error } = await sb.auth.updateUser({ password: s1 });
      if (error) { msg.textContent = 'Erro: ' + error.message; msg.className = 'msg erro'; return; }
      msg.innerHTML = 'Senha alterada! <a href="' + base.replace(/\/$/, '') + '/mesas">Ir para Minhas Mesas</a>.'; msg.className = 'msg ok';
    });
  }
</script>

<style>
  .painel { border: 1px solid var(--rule); border-radius: 8px; padding: 1rem 1.2rem; background: var(--panel); max-width: 30rem; }
  form label { display: block; margin-bottom: .7rem; font-weight: 600; }
  form input { display: block; width: 100%; margin-top: .25rem; padding: .5rem; border: 1px solid var(--rule); border-radius: 6px; background: var(--bg); color: var(--ink); font: inherit; }
  .msg { display: inline-block; margin-left: .6rem; } .msg.erro { color: #b3261e; } .msg.ok { color: var(--accent); }
  .aviso { border: 1px solid var(--gold, var(--rule)); border-radius: 8px; padding: 1rem; background: color-mix(in srgb, var(--gold, #caa) 12%, transparent); max-width: 40rem; }
</style>
