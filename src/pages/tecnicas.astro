---
import Base from '../layouts/Base.astro';
import { url } from '../lib/site';
import { loadData, BANDA_LABEL, custoTagTecnica } from '../lib/data';
const d = await loadData();
const techs = [...d.tecnicas].sort((a, b) => (d.C[a.caminho.id].nome).localeCompare(d.C[b.caminho.id].nome) || a.banda - b.banda);
---
<Base title="Técnicas" largura="wide" descricao="Todas as Técnicas dos Caminhos, com filtros por atributo, caminho, banda, tipo e custo.">
  <h1>Técnicas</h1>
  <p class="lead">As {techs.length} Técnicas de todos os Caminhos. Filtre por atributo, caminho, banda ou tipo — ou busque pelo nome.</p>

  <div class="filtros panel" role="region" aria-label="Filtros">
    <div class="f-row">
      <label>Buscar<input type="search" data-f="q" placeholder="nome ou efeito…" /></label>
      <label>Atributo<select data-f="atributo"><option value="">todos</option>{d.atributos.map((a) => <option value={a.id}>{a.nome}</option>)}</select></label>
      <label>Caminho<select data-f="caminho"><option value="">todos</option>{[...d.caminhos].sort((a, b) => a.nome.localeCompare(b.nome)).map((c) => <option value={c.id} data-atr={c.atributo.id}>{c.nome}</option>)}</select></label>
    </div>
    <div class="f-row">
      <fieldset><legend>Banda</legend>{[1, 2, 3, 4, 5].map((b) => <label class="chk"><input type="checkbox" data-f="banda" value={b} />{b}</label>)}</fieldset>
      <fieldset><legend>Tipo</legend>{['passiva', 'ativa', 'reflexiva'].map((t) => <label class="chk"><input type="checkbox" data-f="tipo" value={t} />{t}</label>)}</fieldset>
      <button class="btn" data-f="clear">Limpar</button>
    </div>
    <p class="muted f-count" data-f="count"></p>
  </div>

  <div class="tec-list">
    {techs.map((t) => (
      <a class="tec-row" href={url(`caminhos/${t.caminho.id}`) + '#' + t.id}
         data-atributo={t.atributo.id} data-caminho={t.caminho.id} data-banda={t.banda} data-tipo={t.tipo}
         data-nome={t.nome.toLowerCase()} data-texto={t.texto.toLowerCase()}>
        <span class="tr-nome cinzel">{t.nome}</span>
        <span class="tr-cam muted">{d.C[t.caminho.id].nome}</span>
        <span class="badge banda">B{t.banda}</span>
        <span class={`badge ${t.tipo}`}>{custoTagTecnica(t)}</span>
        <span class="tr-eff" set:html={t.texto.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')} />
      </a>
    ))}
  </div>
</Base>

<style>
  .filtros { margin: 1rem 0 1.4rem; }
  .f-row { display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end; margin-bottom: .6rem; }
  .filtros label { display: flex; flex-direction: column; font-size: .78rem; font-family: 'Cinzel'; color: var(--ink-soft); gap: .2rem; }
  .filtros input, .filtros select { padding: .35rem .5rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); font-size: .95rem; min-width: 9rem; }
  .filtros fieldset { border: 1px solid var(--panel-border); border-radius: 5px; padding: .3rem .6rem; }
  .filtros legend { font-family: 'Cinzel'; font-size: .72rem; color: var(--ink-soft); padding: 0 .3rem; }
  .chk { flex-direction: row !important; align-items: center; gap: .25rem; display: inline-flex; margin-right: .5rem; }
  .tec-list { display: flex; flex-direction: column; }
  .tec-row { display: grid; grid-template-columns: minmax(9rem, 1.2fr) minmax(7rem, 1fr) auto auto; gap: .5rem .7rem;
    align-items: baseline; padding: .55rem .2rem; border-bottom: 1px solid var(--rule); text-decoration: none; color: inherit; }
  .tec-row:hover { background: var(--panel-2); }
  .tr-nome { color: var(--accent); }
  .tr-eff { grid-column: 1 / -1; font-size: .92rem; color: var(--ink-soft); }
  @media (max-width: 640px) { .tec-row { grid-template-columns: 1fr auto; } .tr-cam { grid-column: 1; } }
</style>

<script>
  const root = document.currentScript?.previousElementSibling;
  const get = (s: string) => Array.from(document.querySelectorAll<HTMLInputElement>(`[data-f="${s}"]`));
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.tec-row'));
  const countEl = document.querySelector<HTMLElement>('[data-f="count"]')!;
  const q = () => (document.querySelector('[data-f="q"]') as HTMLInputElement).value.trim().toLowerCase();
  const sel = (s: string) => (document.querySelector(`[data-f="${s}"]`) as HTMLSelectElement)?.value;
  const checked = (s: string) => get(s).filter((c) => c.checked).map((c) => c.value);

  function apply() {
    const text = q(), atr = sel('atributo'), cam = sel('caminho');
    const bandas = checked('banda'), tipos = checked('tipo');
    let n = 0;
    for (const r of rows) {
      const ok =
        (!atr || r.dataset.atributo === atr) &&
        (!cam || r.dataset.caminho === cam) &&
        (!bandas.length || bandas.includes(r.dataset.banda!)) &&
        (!tipos.length || tipos.includes(r.dataset.tipo!)) &&
        (!text || r.dataset.nome!.includes(text) || r.dataset.texto!.includes(text));
      r.style.display = ok ? '' : 'none';
      if (ok) n++;
    }
    countEl.textContent = `${n} Técnica${n === 1 ? '' : 's'}`;
  }
  // caminho restringe ao atributo escolhido
  const camSel = document.querySelector<HTMLSelectElement>('[data-f="caminho"]');
  document.querySelector('[data-f="atributo"]')?.addEventListener('change', () => {
    const atr = sel('atributo');
    camSel?.querySelectorAll('option').forEach((o) => {
      const oa = (o as HTMLOptionElement).dataset.atr;
      (o as HTMLOptionElement).hidden = !!atr && !!oa && oa !== atr;
    });
    if (atr && camSel && camSel.selectedOptions[0]?.hidden) camSel.value = '';
    apply();
  });
  document.querySelectorAll('[data-f]').forEach((el) => el.addEventListener('input', apply));
  document.querySelector('[data-f="clear"]')?.addEventListener('click', () => {
    (document.querySelector('[data-f="q"]') as HTMLInputElement).value = '';
    (document.querySelector('[data-f="atributo"]') as HTMLSelectElement).value = '';
    if (camSel) { camSel.value = ''; camSel.querySelectorAll('option').forEach((o) => ((o as HTMLOptionElement).hidden = false)); }
    get('banda').concat(get('tipo')).forEach((c) => (c.checked = false));
    apply();
  });
  apply();
</script>
