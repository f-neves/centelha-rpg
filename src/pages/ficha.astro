  .dot { width: 15px; height: 15px; border: 1.5px solid var(--accent); border-radius: 50%; cursor: pointer; background: transparent; transition: background .08s; flex: 0 0 auto; }
  .dot.on { background: var(--accent); } .dot.free { border-color: var(--gold); } .dot.on.free { background: var(--gold); }
  .dot:hover { box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent); }
  .dots:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }
  .cam-tools { margin: 0 0 .5rem; }
