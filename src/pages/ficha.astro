  .sq.on { background: var(--gold); border-color: var(--gold); } .sq.dis { opacity: .28; cursor: not-allowed; }

  #derived { border: 1px solid var(--panel-border); background: var(--panel); border-left: 4px solid var(--accent); padding: .6rem .8rem; border-radius: 3px; }
  .derv { display: flex; justify-content: space-between; align-items: baseline; padding: .2rem 0; border-bottom: 1px dotted var(--rule); }
