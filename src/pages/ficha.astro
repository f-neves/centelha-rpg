---
import Base from '../layouts/Base.astro';
import RoladorDados from '../components/RoladorDados.astro';
import { loadData } from '../lib/data';
const d = await loadData();
const grpAttr: Record<string, string> = { fisico: 'Físicos', social: 'Sociais', mental: 'Mentais' };
const grpHab: Record<string, string> = { combate: 'Combate', fisica: 'Físicas & Mobilidade', social: 'Sociais', saber: 'Saber', tecnica: 'Técnicas' };
const attrsByGrp = (g: string) => d.atributos.filter((a) => a.grupo === g);
const habsByGrp = (g: string) => d.habilidades.filter((h) => h.grupo === g);
const caminhosOrd = [...d.caminhos].sort((a, b) => a.nome.localeCompare(b.nome));
---
<Base title="Ficha de Personagem" largura="wide" descricao="Monte um personagem com XP ao vivo: atributos, perícias, virtudes, Técnicas e Artes, com todos os derivados calculados.">
  <h1>Ficha de Personagem</h1>
  <p class="lead">Gaste XP a partir dos pisos. Tudo se calcula ao vivo — XP, Defesa, PV, Energia, Mana. Salva sozinho neste aparelho; compartilhe pelo botão de link.</p>

  <div class="ficha-top">
    <label class="fld grow">Nome<input id="f-nome" type="text" placeholder="Seu herói" /></label>
    <label class="fld">Orçamento de XP<input id="f-orc" type="number" min="0" value="400" /></label>
    <div class="btn-row">
      <button class="btn" id="f-kael">Carregar Kael</button>
      <button class="btn" id="f-link">Copiar link</button>
      <button class="btn" id="f-reset">Resetar</button>
    </div>
  </div>

  <div id="painel" class="painel" aria-live="polite"></div>

  <div class="ficha-cols">
    <section>
      <h2>Atributos</h2>
      {['fisico', 'social', 'mental'].map((g) => (
        <div class="bloco">
          <h4>{grpAttr[g]}</h4>
          {attrsByGrp(g).map((a) => (
            <div class="trait"><span class="t-nome">{a.nome}</span>
              <input class="t-val" type="number" min="1" max="10" data-trait="attr" data-id={a.id} value="2" /></div>
          ))}
        </div>
      ))}

      <h2>Virtudes & Poder</h2>
      <div class="bloco">
        {d.virtudes.map((v) => (
          <div class="trait"><span class="t-nome">{v.nome}</span>
            <input class="t-val" type="number" min="1" max="5" data-trait="virt" data-id={v.id} value="1" /></div>
        ))}
        <div class="trait"><span class="t-nome">Força de Vontade</span>
          <input class="t-val" type="number" min="5" max="10" data-trait="vontade" data-id="vontade" value="5" /></div>
        <div class="trait"><span class="t-nome">Centelha</span>
          <input class="t-val" type="number" min="0" max="5" data-trait="centelha" data-id="centelha" value="0" /></div>
      </div>
    </section>

    <section>
      <h2>Habilidades</h2>
      <p class="muted" style="font-size:.82rem;margin-top:-.4rem">valor · <span style="color:var(--gold)">especialidade</span></p>
      {['combate', 'fisica', 'social', 'saber', 'tecnica'].map((g) => (
        <div class="bloco">
          <h4>{grpHab[g]}</h4>
          {habsByGrp(g).map((h) => (
            <div class="trait skill"><span class="t-nome">{h.nome}</span>
              <input class="t-val" type="number" min="0" max="10" data-trait="skill" data-id={h.id} value="0" />
              <input class="t-esp" type="number" min="0" max="10" data-trait="spec" data-id={h.id} value="0" title="Especialidade" />
            </div>
          ))}
        </div>
      ))}
    </section>

    <section>
      <h2>Técnicas</h2>
      <div class="add-row">
        <select id="f-tec-sel">
          <option value="">— escolher Técnica —</option>
          {caminhosOrd.map((c) => (
            <optgroup label={c.nome}>
              {d.porCaminho[c.id]?.map((t) => <option value={t.id}>{t.nome} (B{t.banda})</option>)}
            </optgroup>
          ))}
        </select>
        <button class="btn" id="f-tec-add">Adicionar</button>
      </div>
      <ul id="f-tec-list" class="chosen"></ul>

      <h2>Artes</h2>
      <div class="bloco artes-grid">
        {[...d.artes].sort((a, b) => a.nome.localeCompare(b.nome)).map((a) => (
          <div class="trait"><span class="t-nome">{a.nome}</span>
            <input class="t-val" type="number" min="0" max="5" data-trait="arte" data-id={a.id} value="0" /></div>
        ))}
      </div>
    </section>
  </div>

  <h2>Rolar</h2>
  <RoladorDados compact />
</Base>

<script>
  import { custoPontos, custoTecnica, custoArte, pv, defesa, defesaMental, energia, mana, iniciativa } from '../lib/calc';
  import tecnicas from '../data/tecnicas.json';
  const TEC: Record<string, any> = Object.fromEntries((tecnicas as any[]).map((t) => [t.id, t]));

  const KEY = 'centelha:ficha';
  const BASE = import.meta.env.BASE_URL;
  const $ = <T extends HTMLElement>(s: string) => document.querySelector(s) as T;
  const inputs = () => Array.from(document.querySelectorAll<HTMLInputElement>('[data-trait]'));
  const painel = $('#painel');
  let tecSel: string[] = [];

  function collect() {
    const s: any = { nome: ($('#f-nome') as HTMLInputElement).value, orc: +($('#f-orc') as HTMLInputElement).value || 0, t: {}, tec: tecSel };
    for (const el of inputs()) { (s.t[el.dataset.trait!] ??= {})[el.dataset.id!] = +el.value || 0; }
    return s;
  }
  function applyState(s: any) {
    ($('#f-nome') as HTMLInputElement).value = s.nome || '';
    ($('#f-orc') as HTMLInputElement).value = s.orc ?? 400;
    for (const el of inputs()) { const v = s.t?.[el.dataset.trait!]?.[el.dataset.id!]; if (v != null) el.value = String(v); }
    tecSel = Array.isArray(s.tec) ? s.tec : [];
    renderTec(); recompute();
  }

  function xpBreakdown(s: any) {
    const t = s.t;
    const attr = Object.values(t.attr || {}).reduce((sum: number, v: any) => sum + custoPontos('atributo', 2, v), 0);
    const skill = Object.values(t.skill || {}).reduce((sum: number, v: any) => sum + custoPontos('habilidadePrimaria', 0, v), 0);
    const spec = Object.values(t.spec || {}).reduce((sum: number, v: any) => sum + v * 10, 0);
    const virt = Object.values(t.virt || {}).reduce((sum: number, v: any) => sum + custoPontos('virtude', 1, v), 0);
    const vont = custoPontos('vontade', 5, t.vontade?.vontade ?? 5);
    const cent = custoPontos('centelha', 0, t.centelha?.centelha ?? 0);
    const tec = tecSel.reduce((sum, id) => sum + custoTecnica(TEC[id]?.banda ?? 1), 0);
    const arte = Object.values(t.arte || {}).reduce((sum: number, n: any) => sum + custoArte(n), 0);
    const total = attr + skill + spec + virt + vont + cent + tec + arte;
    return { attr, skill, spec, virt, vont, cent, tec, arte, total };
  }

  function recompute() {
    const s = collect();
    const t = s.t;
    const g = (grp: string, id: string) => t[grp]?.[id] ?? 0;
    const virt = { compaixao: g('virt', 'compaixao'), conviccao: g('virt', 'conviccao'), temperanca: g('virt', 'temperanca'), valor: g('virt', 'valor') };
    const cent = g('centelha', 'centelha'), vont = g('vontade', 'vontade');
    const der = {
      pv: pv(g('attr', 'vigor')),
      defesa: defesa({ destreza: g('attr', 'destreza'), habilidade: g('skill', 'esquiva'), especialidade: g('spec', 'esquiva'), centelha: cent }),
      defesaMental: defesaMental({ virtudes: virt, vontade: vont, centelha: cent }),
      energia: energia({ centelha: cent, virtudes: virt, vontade: vont }),
      mana: mana({ centelha: cent, vontade: vont }),
      ini: iniciativa({ raciocinio: g('attr', 'raciocinio'), prontidao: g('skill', 'prontidao') }),
    };
    const xp = xpBreakdown(s);
    const rest = s.orc - xp.total;
    painel.innerHTML =
      `<div class="painel-xp ${rest < 0 ? 'over' : ''}"><span class="big">${xp.total}</span> / ${s.orc} XP <span class="muted">· restam ${rest}</span></div>` +
      `<div class="painel-bd muted">Atrib ${xp.attr} · Perícias ${xp.skill} · Espec ${xp.spec} · Virtudes ${xp.virt} · Vontade ${xp.vont} · Centelha ${xp.cent} · Técnicas ${xp.tec} · Artes ${xp.arte}</div>` +
      `<div class="painel-der">` +
        `<div><b>PV</b>${der.pv}</div><div><b>Defesa</b>${der.defesa}</div><div><b>Def. Mental</b>${der.defesaMental}</div>` +
        `<div><b>Energia</b>${der.energia}</div><div><b>Mana</b>${der.mana}</div><div><b>Iniciativa</b>${der.ini.str}</div>` +
      `</div>`;
    save(s);
  }

  function renderTec() {
    const ul = $('#f-tec-list');
    ul.innerHTML = tecSel.map((id) => {
      const t = TEC[id]; if (!t) return '';
      return `<li><span><a href="${BASE}caminhos/${t.caminho}#${id}">${t.nome}</a> <span class="muted">B${t.banda} · ${custoTecnica(t.banda)} XP</span></span><button class="rm" data-rm="${id}" aria-label="Remover">✕</button></li>`;
    }).join('');
    ul.querySelectorAll('[data-rm]').forEach((b) => b.addEventListener('click', () => { tecSel = tecSel.filter((x) => x !== (b as HTMLElement).dataset.rm); renderTec(); recompute(); }));
  }

  function custoTecnicaXp(banda: number) { return custoTecnica(banda); }

  function save(s: any) { try { localStorage.setItem(KEY, JSON.stringify(s)); } catch {} }

  // eventos
  inputs().forEach((el) => el.addEventListener('input', recompute));
  $('#f-nome').addEventListener('input', recompute);
  $('#f-orc').addEventListener('input', recompute);
  $('#f-tec-add').addEventListener('click', () => {
    const sel = $('#f-tec-sel') as HTMLSelectElement; const id = sel.value;
    if (id && !tecSel.includes(id)) { tecSel.push(id); renderTec(); recompute(); }
    sel.value = '';
  });
  $('#f-reset').addEventListener('click', () => { if (confirm('Limpar a ficha?')) { localStorage.removeItem(KEY); location.hash = ''; location.reload(); } });
  $('#f-link').addEventListener('click', () => {
    const b64 = btoa(unescape(encodeURIComponent(JSON.stringify(collect()))));
    const u = location.origin + location.pathname + '#p=' + b64;
    navigator.clipboard?.writeText(u); const b = $('#f-link'); b.textContent = 'Link copiado ✓'; setTimeout(() => (b.textContent = 'Copiar link'), 1400);
  });

  // preset Kael (regressão: 375 XP · PV 34 · Defesa 10 · Energia 16 · Mana 7 · Iniciativa 1d6+5)
  const KAEL = { nome: 'Kael, o Batedor', orc: 400,
    t: { attr: { forca: 2, destreza: 4, vigor: 3, carisma: 2, manipulacao: 2, aparencia: 2, percepcao: 3, inteligencia: 2, raciocinio: 3 },
      skill: { furtividade: 3, 'armas-a-distancia': 3, prontidao: 2, atletismo: 2, sobrevivencia: 2, investigacao: 1, briga: 1, esquiva: 1 },
      spec: { furtividade: 1, 'armas-a-distancia': 1 },
      virt: { compaixao: 1, conviccao: 2, temperanca: 2, valor: 3 }, vontade: { vontade: 5 }, centelha: { centelha: 1 }, arte: {} },
    tec: ['pisar-leve', 'esgueirar', 'mira-firme'] };
  $('#f-kael').addEventListener('click', () => applyState(structuredClone(KAEL)));

  // init: URL > localStorage > vazio
  function init() {
    const m = location.hash.match(/p=([^&]+)/);
    if (m) { try { return applyState(JSON.parse(decodeURIComponent(escape(atob(m[1]))))); } catch {} }
    try { const raw = localStorage.getItem(KEY); if (raw) return applyState(JSON.parse(raw)); } catch {}
    renderTec(); recompute();
  }
  init();
</script>

<style>
  .ficha-top { display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; margin: 1rem 0; }
  .fld { display: flex; flex-direction: column; font-family: 'Cinzel'; font-size: .78rem; color: var(--ink-soft); gap: .2rem; }
  .fld.grow { flex: 1; min-width: 12rem; }
  .fld input { padding: .4rem .5rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); font-size: 1rem; }
  .painel { background: var(--panel); border: 1px solid var(--accent); border-radius: 8px; padding: .7rem 1rem; margin-bottom: 1.4rem; box-shadow: 0 2px 8px var(--shadow); }
  .painel-xp .big { font-family: 'Cinzel'; font-size: 1.6rem; color: var(--accent); }
  .painel-xp.over .big { color: #b3401f; }
  .painel-bd { font-size: .8rem; margin: .2rem 0 .5rem; }
  .painel-der { display: flex; flex-wrap: wrap; gap: .4rem 1.1rem; }
  .painel-der div { font-size: .95rem; } .painel-der b { font-family: 'Cinzel'; color: var(--accent); font-size: .72rem; display: block; }
  .ficha-cols { display: grid; grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr)); gap: 1.4rem 2rem; align-items: start; }
  .bloco { margin-bottom: 1rem; }
  .trait { display: flex; align-items: center; gap: .5rem; padding: .15rem 0; }
  .t-nome { flex: 1; }
  .t-val { width: 3.4rem; padding: .25rem; text-align: center; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); }
  .t-esp { width: 2.8rem; padding: .25rem; text-align: center; border: 1px dashed var(--gold); border-radius: 4px; background: var(--bg); color: var(--ink); }
  .add-row { display: flex; gap: .5rem; }
  .add-row select { flex: 1; padding: .4rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); }
  .chosen { list-style: none; padding: 0; margin: .6rem 0; }
  .chosen li { display: flex; justify-content: space-between; align-items: center; padding: .3rem .2rem; border-bottom: 1px solid var(--rule); }
  .chosen .rm { background: none; border: none; color: var(--ink-soft); cursor: pointer; font-size: 1rem; }
  .artes-grid { columns: 2; }
  @media (max-width: 520px) { .artes-grid { columns: 1; } }
</style>
