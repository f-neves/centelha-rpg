  .cam-meta { margin-left: auto; font-family: 'EB Garamond'; font-size: .8rem; color: var(--ink-soft); font-style: italic; }
  .cam-body { padding: .4rem .7rem .6rem; border-top: 1px dotted var(--rule); }
  .tpill { display: inline-block; margin: .2rem .3rem 0 0; padding: .2rem .6rem; border: 1px solid var(--panel-border); border-radius: 12px; font-size: .85rem; cursor: pointer; background: var(--bg); }
  .tpill small { color: var(--ink-soft); font-size: .72rem; }
  .tpill.on { background: var(--accent); color: var(--on-accent); border-color: transparent; } .tpill.on small { color: var(--on-accent); opacity: .85; }
  .tpill:hover { box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 25%, transparent); }
  .tpill.locked { opacity: .5; cursor: not-allowed; border-style: dashed; }
  .tpill.invalid { border-color: #b3401f; box-shadow: 0 0 0 1px #b3401f inset; }
