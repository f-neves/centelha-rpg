  h2.barh { background: var(--accent); color: var(--on-accent); font-family: 'Cinzel'; font-weight: 700; font-size: .82rem; letter-spacing: .06em; text-transform: uppercase; padding: .35rem .7rem; border: none; border-radius: 3px; margin: 1.5rem 0 .7rem; }
  h2.barh small { font-weight: 400; text-transform: none; letter-spacing: 0; font-size: .72rem; opacity: .85; }
  .ficha-x h3, #attrs h3, #skills h3, #secondary h3, #power h3 { font-family: 'Cinzel'; font-size: .72rem; color: var(--accent-strong); letter-spacing: .04em; text-transform: uppercase; margin: .9rem 0 .35rem; border-bottom: 1px solid var(--rule); padding-bottom: .15rem; }

