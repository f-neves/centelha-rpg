---
import Base from '../layouts/Base.astro';
import RoladorDados from '../components/RoladorDados.astro';
---
<Base title="Ficha de Personagem" largura="wide" descricao="Monte um personagem com XP ao vivo: atributos, perícias, secundárias, Técnicas e Artes — tudo por bolinhas, com os derivados calculados.">
  <h1>Ficha de Personagem</h1>

  <div class="xpbar" id="painel">
    <span class="big">XP: <b id="xpSpent">0</b></span>
    <label>Orçamento <input type="number" id="xpBudget" value="400" /></label>
    <span class="big">Restam: <b id="xpRem" class="rem ok">400</b></span>
    <span class="breakdown" id="xpBreak"></span>
    <span class="modo-wrap"><span class="modo-lbl">Modo</span>
      <span class="modo-toggle" role="group" aria-label="Modo da ficha">
        <button class="btn" data-modo="criacao" title="Aplica os limites de criação (Atrib 4 · Hab 3 · Centelha 2)">Criação</button>
        <button class="btn" data-modo="evolucao" title="Libera além dos limites de criação (em jogo)">Evolução</button>
      </span>
    </span>
    <span class="xp-btns">
      <button class="btn" id="f-kael">Kael</button>
      <button class="btn" id="f-export">Exportar</button>
      <button class="btn" id="f-import">Importar</button>
      <button class="btn" id="f-print">Imprimir</button>
      <button class="btn" id="f-link">Link</button>
      <button class="btn" id="f-reset">Resetar</button>
      <input type="file" id="f-file" accept="application/json,.json" hidden />
    </span>
  </div>

  <div class="idrow">
    <label>Nome<input class="txt" data-id="nome" placeholder="Seu herói" /></label>
    <label>Conceito<input class="txt" data-id="conceito" /></label>
    <label>Jogador<input class="txt" data-id="jogador" /></label>
  </div>

  <h2 class="barh">Atributos <small>(piso 2 · nível×10)</small></h2>
  <div class="cols3" id="attrs"></div>

  <div class="cols2">
    <div>
      <h2 class="barh">Centelha, Virtudes &amp; Vontade</h2>
      <div id="power"></div>
    </div>
    <div>
      <h2 class="barh">Derivados <small>(calculados)</small></h2>
      <div class="panel" id="derived"></div>
    </div>
  </div>

  <h2 class="barh">Habilidades <small>(piso 0 · nível×5 · ☐ especialidade ×10)</small></h2>
  <div class="cols3" id="skills"></div>

  <h2 class="barh">Habilidades Secundárias <small>(nível×2 · esp. ×5)</small></h2>
  <div class="cols3" id="secondary"></div>

  <h2 class="barh">Caminhos &amp; Técnicas <small>(custo banda×5)</small></h2>
  <div id="tecnicas"></div>

  <h2 class="barh">Arcano — Artes <small>(nível×10 · exige Centelha ≥ nível e Ocultismo ≥ nível)</small></h2>
  <div id="artes"></div>

  <h2 class="barh">Rolar</h2>
  <RoladorDados compact />
</Base>

<script>
  import { custoPontos, custoTecnica, custoArte, pv, defesa, defesaMental, energia, mana, iniciativa, regras } from '../lib/calc';
  import ATTRS_D from '../data/atributos.json';
  import HAB_D from '../data/habilidades.json';
  import VIRT_D from '../data/virtudes.json';
  import CAM_D from '../data/caminhos.json';
  import TEC_D from '../data/tecnicas.json';
  import ARTE_D from '../data/artes.json';

  const el = (id: string) => document.getElementById(id)!;
  const slug = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  const KEY = 'centelha:ficha';
  const BASE = import.meta.env.BASE_URL;

  const ATTR_GRP: Record<string, string> = { fisico: 'Físicos', social: 'Sociais', mental: 'Mentais' };
  const HAB_GRP: Record<string, string> = { combate: 'Combate', fisica: 'Físicas', social: 'Sociais', saber: 'Saber', tecnica: 'Técnicas' };
  const SECONDARY: [string, string][] = [
    ['Atuação', 'Sociais'], ['Sedução', 'Sociais'], ['Liderança', 'Sociais'], ['Disfarce', 'Sociais'], ['Interrogatório', 'Sociais'],
    ['Burocracia', 'Conhecimento'], ['Herbologia', 'Conhecimento'], ['História', 'Conhecimento'], ['Religião', 'Conhecimento'], ['Heráldica', 'Conhecimento'], ['Astronomia', 'Conhecimento'], ['Geografia', 'Conhecimento'], ['Alquimia', 'Conhecimento'], ['Arquitetura', 'Conhecimento'], ['Direito', 'Conhecimento'], ['Bestiário', 'Conhecimento'], ['Estratégia', 'Conhecimento'], ['Genealogia', 'Conhecimento'], ['Folclore', 'Conhecimento'],
    ['Ferraria', 'Ofício'], ['Carpintaria', 'Ofício'], ['Costura', 'Ofício'], ['Culinária', 'Ofício'], ['Joalheria', 'Ofício'], ['Couraria', 'Ofício'], ['Alvenaria', 'Ofício'], ['Mineração', 'Ofício'], ['Pesca', 'Ofício'], ['Agricultura', 'Ofício'], ['Navegação', 'Ofício'], ['Marcenaria', 'Ofício'], ['Armadureiro', 'Ofício'], ['Armeiro', 'Ofício'], ['Escrivania', 'Ofício'], ['Cartografia', 'Ofício'], ['Veterinário', 'Ofício'], ['Adestramento', 'Ofício'],
    ['Tocar Instrumento', 'Expressão'], ['Canto', 'Expressão'], ['Dança', 'Expressão'], ['Poesia', 'Expressão'], ['Pintura', 'Expressão'], ['Escultura', 'Expressão'], ['Caligrafia', 'Expressão'], ['Contação de Histórias', 'Expressão'],
    ['Jogos', 'Subterfúgio'], ['Falsificação', 'Subterfúgio'], ['Prestidigitação', 'Subterfúgio'], ['Abrir Fechaduras', 'Subterfúgio'], ['Contrabando', 'Subterfúgio'], ['Apostar', 'Subterfúgio'], ['Roubo', 'Subterfúgio'], ['Ocultação', 'Subterfúgio'], ['Vigilância Urbana', 'Subterfúgio'],
    ['Meditação', 'Interior'], ['Ritualismo', 'Interior'], ['Autocontrole', 'Interior'], ['Concentração', 'Interior'], ['Leitura Corporal', 'Interior'], ['Interpretação de Sonhos', 'Interior'],
  ];

  const CAM_ORDER = (CAM_D as any[]).map((c) => c.id);
  const CAM_NOME: Record<string, string> = Object.fromEntries((CAM_D as any[]).map((c) => [c.id, c.nome]));
  const CAMTREE: Record<string, [string, string, number][]> = {};
  for (const t of TEC_D as any[]) (CAMTREE[t.caminho] ??= []).push([t.id, t.nome, t.banda]);
  for (const k in CAMTREE) CAMTREE[k].sort((a, b) => a[2] - b[2]);
  const TECBAND: Record<string, number> = Object.fromEntries((TEC_D as any[]).map((t) => [t.id, t.banda]));
  const TECPRE: Record<string, string[]> = Object.fromEntries((TEC_D as any[]).map((t) => [t.id, t.prereq || []]));
  const TECNOME: Record<string, string> = Object.fromEntries((TEC_D as any[]).map((t) => [t.id, t.nome]));
  const CREA = (regras as any).limitesCriacao as { atributo: number; habilidade: number; centelha: number };
  const centReq = (b: number) => Math.ceil(b / 3);
  // teto de cada tipo conforme o modo (criação aplica os limites; evolução libera)
  function capFor(kind: string): number {
    if (kind === 'arte2') return Math.min(S.centelha || 0, S.skills?.ocultismo || 0); // Arte ≤ Centelha e ≤ Ocultismo
    const full: Record<string, number> = { attr: 5, skill: 5, skill2: 5, virtue: 5, centelha: 5, willpower: 10 };
    if (S.modo === 'evolucao') return full[kind] ?? 5;
    const crea: Record<string, number> = { attr: CREA.atributo, skill: CREA.habilidade, skill2: CREA.habilidade, virtue: 5, centelha: CREA.centelha, willpower: 10 };
    return crea[kind] ?? 5;
  }

  // ---- estado ----
  let S: any;
  const OPEN = { cam: {} as Record<string, boolean>, arte: {} as Record<string, boolean> };
  function fresh() {
    S = { id: {}, attrs: {}, skills: {}, spec: {}, skills2: {}, spec2: {}, virtues: {}, willpower: 5, centelha: 0, tech: {}, arte: {}, budget: 400, modo: 'criacao' };
    (ATTRS_D as any[]).forEach((a) => (S.attrs[a.id] = 2));
    (HAB_D as any[]).forEach((h) => { S.skills[h.id] = 0; S.spec[h.id] = 0; });
    (VIRT_D as any[]).forEach((v) => (S.virtues[v.id] = 1));
    SECONDARY.forEach(([n]) => { S.skills2[slug(n)] = 0; S.spec2[slug(n)] = 0; });
  }
  function normalize() {
    S.id ??= {}; S.attrs ??= {}; S.skills ??= {}; S.spec ??= {}; S.skills2 ??= {}; S.spec2 ??= {}; S.virtues ??= {}; S.tech ??= {}; S.arte ??= {};
    S.willpower ??= 5; S.centelha ??= 0; S.budget ??= 400; S.modo ??= 'criacao';
    (ATTRS_D as any[]).forEach((a) => (S.attrs[a.id] ??= 2));
    (HAB_D as any[]).forEach((h) => { S.skills[h.id] ??= 0; S.spec[h.id] ??= 0; });
    (VIRT_D as any[]).forEach((v) => (S.virtues[v.id] ??= 1));
    SECONDARY.forEach(([n]) => { const k = slug(n); S.skills2[k] ??= 0; S.spec2[k] ??= 0; });
  }
  const save = () => { try { localStorage.setItem(KEY, JSON.stringify(S)); } catch {} };

  // ---- builders ----
  const dotsHTML = (kind: string, key: string, value: number, max: number, floor: number) => {
    const cap = capFor(kind);
    let h = `<span class="dots" data-kind="${kind}" data-key="${key}">`;
    for (let d = 1; d <= max; d++) {
      const capped = d > cap;
      const tip = capped ? ' title="Limite de criação — ative \'Evolução\' na barra de XP para passar daqui"' : '';
      h += `<span class="dot${d <= value ? ' on' : ''}${d <= floor ? ' free' : ''}${capped ? ' cap' : ''}" data-d="${d}"${tip}></span>`;
    }
    return h + '</span>';
  };
  const specHTML = (key: string, value: number, maxAllowed: number) => {
    let h = `<span class="spec" data-spec="${key}">`;
    for (let d = 1; d <= 5; d++) h += `<span class="sq${d <= value ? ' on' : ''}${d > maxAllowed ? ' dis' : ''}" data-d="${d}"></span>`;
    return h + '</span>';
  };
  const trow = (nm: string, right: string) => `<div class="trow"><span class="nm">${nm}</span><span class="tr-r">${right}</span></div>`;
  const rollBtn = (k: string, key: string) => `<button class="rollv" data-roll="${k}:${key}" title="Enviar ao rolador" aria-label="Rolar">🎲</button>`;

  // ---- render ----
  function renderAttrs() {
    const groups: Record<string, any[]> = { Físicos: [], Sociais: [], Mentais: [] };
    (ATTRS_D as any[]).forEach((a) => groups[ATTR_GRP[a.grupo]].push(a));
    el('attrs').innerHTML = ['Físicos', 'Sociais', 'Mentais'].map((g) =>
      `<div><h3>${g}</h3>${groups[g].map((a) => trow(a.nome, dotsHTML('attr', a.id, S.attrs[a.id], 5, 2) + rollBtn('attr', a.id))).join('')}</div>`).join('');
  }
  function renderPower() {
    let h = trow('<b>Centelha</b> <small>(0–5)</small>', dotsHTML('centelha', 'centelha', S.centelha, 5, 0));
    h += '<h3>Virtudes</h3>';
    (VIRT_D as any[]).forEach((v) => (h += trow(v.nome, dotsHTML('virtue', v.id, S.virtues[v.id], 5, 1))));
    h += '<h3>Força de Vontade <small>(piso 5 · ×2)</small></h3>';
    h += trow('Vontade', dotsHTML('willpower', 'willpower', S.willpower, 10, 5));
    el('power').innerHTML = h;
  }
  function renderSkills() {
    const groups: Record<string, any[]> = { Combate: [], Físicas: [], Sociais: [], Saber: [], Técnicas: [] };
    (HAB_D as any[]).forEach((s) => groups[HAB_GRP[s.grupo]].push(s));
    const cols = [['Combate', 'Físicas'], ['Sociais', 'Saber'], ['Técnicas']];
    el('skills').innerHTML = cols.map((col) => '<div>' + col.map((g) =>
      `<h3>${g}</h3>` + groups[g].map((s) => trow(s.nome, dotsHTML('skill', s.id, S.skills[s.id], 5, 0) + specHTML(s.id, S.spec[s.id] || 0, S.skills[s.id] || 0) + rollBtn('skill', s.id))).join('')).join('') + '</div>').join('');
  }
  function renderSecondary() {
    const groups: Record<string, string[]> = {}; SECONDARY.forEach(([n, g]) => (groups[g] ??= []).push(n));
    const cols = [['Sociais', 'Conhecimento'], ['Ofício'], ['Expressão', 'Subterfúgio', 'Interior']];
    el('secondary').innerHTML = cols.map((col) => '<div>' + col.map((g) =>
      `<h3>${g}</h3>` + (groups[g] || []).map((n) => { const k = slug(n); return trow(n, dotsHTML('skill2', k, S.skills2[k] || 0, 5, 0) + specHTML('2_' + k, S.spec2[k] || 0, S.skills2[k] || 0)); }).join('')).join('') + '</div>').join('');
  }
  function renderCaminhos() {
    el('tecnicas').innerHTML = CAM_ORDER.map((cam) => {
      const techs = CAMTREE[cam] || [];
      const sel = techs.filter(([id]) => S.tech[id]);
      const cost = sel.reduce((s, [, , b]) => s + b * 5, 0);
      const open = OPEN.cam[cam];
      const pills = techs.map(([id, nome, b]) => {
        const owned = !!S.tech[id];
        const centOk = (S.centelha || 0) >= centReq(b);
        const miss = (TECPRE[id] || []).filter((p) => !S.tech[p]);
        const ok = centOk && miss.length === 0;
        const cls = 'tpill' + (owned ? ' on' : '') + (!owned && !ok ? ' locked' : '') + (owned && !ok ? ' invalid' : '');
        const reasons: string[] = []; if (!centOk) reasons.push('Centelha ' + centReq(b)); if (miss.length) reasons.push('pré: ' + miss.map((p) => TECNOME[p]).join(', '));
        const title = reasons.length ? ` title="Requer ${reasons.join(' · ').replace(/"/g, '')}"` : '';
        return `<span class="${cls}" data-tech="${id}"${title}>${!owned && !ok ? '🔒 ' : ''}${nome} <small>b${b} · ${b * 5}</small></span>`;
      }).join('');
      return `<div class="cam"><div class="cam-head" data-camtog="${cam}"><span class="chev">${open ? '▾' : '▸'}</span><span class="cam-nm">Caminho ${CAM_NOME[cam]}</span><span class="cam-meta">${sel.length ? `${sel.length} téc · ${cost} XP` : '—'}</span></div><div class="cam-body" style="display:${open ? 'block' : 'none'}">${pills}</div></div>`;
    }).join('');
  }
  function renderArtes() {
    el('artes').innerHTML = (ARTE_D as any[]).map((a) => {
      const lvl = S.arte[a.id] || 0, cost = custoArte(lvl), open = OPEN.arte[a.id];
      const fx = a.niveis.map((n: any) => `<div class="fxline${n.nivel <= lvl ? ' hi' : ''}">${n.nivel} — <b>${n.nome}</b>: ${n.efeito}</div>`).join('');
      return `<div class="cam"><div class="cam-head"><span class="chev" data-artetog="${a.id}">${open ? '▾' : '▸'} ${a.nome}</span>${dotsHTML('arte2', a.id, lvl, 5, 0)}<span class="cam-meta">${lvl ? `nível ${lvl} · ${cost} XP` : '—'}</span></div><div class="cam-body" style="display:${open ? 'block' : 'none'}">${fx}</div></div>`;
    }).join('');
  }
  const A = (id: string) => S.attrs[id] || 0, SK = (id: string) => S.skills[id] || 0, SP = (id: string) => S.spec[id] || 0, VI = (id: string) => S.virtues[id] || 0;
  function renderDerived() {
    const virt = { compaixao: VI('compaixao'), conviccao: VI('conviccao'), temperanca: VI('temperanca'), valor: VI('valor') };
    const C = S.centelha, W = S.willpower, integ = virt.compaixao + virt.temperanca;
    const r = (l: string, v: any, fm: string) => `<div class="derv"><span class="dl">${l}<span class="fm">${fm}</span></span><span class="dv">${v}</span></div>`;
    el('derived').innerHTML =
      r('Pontos de Vida', pv(A('vigor')), '25 + Vigor×3') +
      r('Defesa (Esquiva)', defesa({ destreza: A('destreza'), habilidade: SK('esquiva'), especialidade: SP('esquiva'), centelha: C }), '(Des+Esquiva)×2 − ⌊/4⌋ + esp + ⌈Cent/2⌉') +
      r('Defesa Mental', defesaMental({ virtudes: virt, vontade: W, centelha: C }), `⌊(Integridade ${integ} + Vontade)/2⌋ + Centelha`) +
      r('Energia', energia({ centelha: C, virtudes: virt, vontade: W }), 'Centelha×3 + Virtudes + Vontade') +
      r('Mana', mana({ centelha: C, vontade: W }), 'Centelha×2 + Vontade') +
      r('Iniciativa', iniciativa({ raciocinio: A('raciocinio'), prontidao: SK('prontidao') }).str, '+ Raciocínio + Prontidão');
  }
  function recompute() {
    let xa = 0, xs = 0, xsp = 0, xv = 0, xw = 0, xc = 0, x2 = 0, xt = 0, xar = 0;
    (ATTRS_D as any[]).forEach((a) => (xa += custoPontos('atributo', 2, S.attrs[a.id] || 2)));
    (HAB_D as any[]).forEach((h) => { xs += custoPontos('habilidadePrimaria', 0, S.skills[h.id] || 0); xsp += (S.spec[h.id] || 0) * 10; });
    (VIRT_D as any[]).forEach((v) => (xv += custoPontos('virtude', 1, S.virtues[v.id] || 1)));
    xw = custoPontos('vontade', 5, S.willpower || 5);
    xc = custoPontos('centelha', 0, S.centelha || 0);
    SECONDARY.forEach(([n]) => { const k = slug(n); x2 += custoPontos('habilidadeSecundaria', 0, S.skills2[k] || 0) + (S.spec2[k] || 0) * 5; });
    Object.keys(S.tech).forEach((id) => { if (S.tech[id] && TECBAND[id]) xt += TECBAND[id] * 5; });
    (ARTE_D as any[]).forEach((a) => (xar += custoArte(S.arte[a.id] || 0)));
    const total = xa + xs + xsp + xv + xw + xc + x2 + xt + xar;
    el('xpSpent').textContent = String(total);
    const rem = (S.budget || 0) - total, re = el('xpRem'); re.textContent = String(rem); re.className = 'rem ' + (rem < 0 ? 'neg' : 'ok');
    el('xpBreak').innerHTML = `Atrib ${xa} · Perícias ${xs + xsp} · Virtudes ${xv} · Vontade ${xw} · Centelha ${xc}` + (x2 ? ` · Secund. ${x2}` : '') + (xt ? ` · Técnicas ${xt}` : '') + (xar ? ` · Artes ${xar}` : '');
    renderDerived(); save();
  }

  // ---- interações ----
  const floorOf: Record<string, number> = { attr: 2, skill: 0, skill2: 0, virtue: 1, centelha: 0, willpower: 5, arte2: 0 };
  const valOf = (k: string, key: string) => ({ attr: S.attrs[key], skill: S.skills[key], skill2: S.skills2[key] || 0, virtue: S.virtues[key], centelha: S.centelha, willpower: S.willpower, arte2: S.arte[key] || 0 } as any)[k] || 0;
  function refreshDots(kind: string, key: string) {
    const span = document.querySelector(`.dots[data-kind="${kind}"][data-key="${key}"]`); if (!span) return;
    const floor = floorOf[kind], val = valOf(kind, key);
    span.querySelectorAll('.dot').forEach((d) => { const dd = +(d as HTMLElement).dataset.d!; d.classList.toggle('on', dd <= val); d.classList.toggle('free', dd <= floor); });
  }
  function setDot(kind: string, key: string, d: number) {
    const floor = floorOf[kind], val = valOf(kind, key);
    let nv = d <= floor ? floor : val === d ? d - 1 : d; if (nv < floor) nv = floor;
    nv = Math.min(nv, capFor(kind)); if (nv < floor) nv = floor;
    if (kind === 'attr') S.attrs[key] = nv;
    else if (kind === 'skill') { S.skills[key] = nv; if ((S.spec[key] || 0) > nv) S.spec[key] = nv; renderSkills(); if (key === 'ocultismo') renderArtes(); }
    else if (kind === 'skill2') { S.skills2[key] = nv; if ((S.spec2[key] || 0) > nv) S.spec2[key] = nv; renderSecondary(); }
    else if (kind === 'virtue') S.virtues[key] = nv;
    else if (kind === 'centelha') { S.centelha = nv; renderCaminhos(); renderArtes(); }
    else if (kind === 'willpower') S.willpower = nv;
    else if (kind === 'arte2') { S.arte[key] = nv; renderArtes(); }
    if (['attr', 'virtue', 'centelha', 'willpower'].includes(kind)) refreshDots(kind, key);
    recompute();
  }
  function setSpec(specKey: string, d: number) {
    if (specKey.startsWith('2_')) { const sl = specKey.slice(2); let nv = (S.spec2[sl] || 0) === d ? d - 1 : d; nv = Math.max(0, Math.min(nv, S.skills2[sl] || 0)); S.spec2[sl] = nv; renderSecondary(); }
    else { let nv = (S.spec[specKey] || 0) === d ? d - 1 : d; nv = Math.max(0, Math.min(nv, S.skills[specKey] || 0)); S.spec[specKey] = nv; renderSkills(); }
    recompute();
  }

  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const dot = t.closest<HTMLElement>('.dots .dot');
    if (dot) { if (dot.classList.contains('cap')) return; const s = dot.parentElement as HTMLElement; setDot(s.dataset.kind!, s.dataset.key!, +dot.dataset.d!); return; }
    const rb = t.closest<HTMLElement>('.rollv');
    if (rb) { const [k, key] = rb.dataset.roll!.split(':'); const rd = (n: string) => document.querySelector<HTMLInputElement>(`[data-rd="${n}"]`);
      if (k === 'attr') { const a = rd('atr'); if (a) { a.value = String(S.attrs[key] || 0); a.dispatchEvent(new Event('input')); } }
      else { const hb = rd('hab'), es = rd('esp'); if (hb) hb.value = String(S.skills[key] || 0); if (es) es.value = String(S.spec[key] || 0); hb?.dispatchEvent(new Event('input')); }
      document.querySelector('.rolador')?.scrollIntoView({ behavior: 'smooth', block: 'center' }); return; }
    const sq = t.closest<HTMLElement>('.spec .sq');
    if (sq && !sq.classList.contains('dis')) { setSpec((sq.parentElement as HTMLElement).dataset.spec!, +sq.dataset.d!); return; }
    const pill = t.closest<HTMLElement>('.tpill');
    if (pill) { if (pill.classList.contains('locked')) return; const id = pill.dataset.tech!; S.tech[id] = !S.tech[id]; renderCaminhos(); recompute(); return; }
    const ct = t.closest<HTMLElement>('[data-camtog]');
    if (ct) { OPEN.cam[ct.dataset.camtog!] = !OPEN.cam[ct.dataset.camtog!]; renderCaminhos(); return; }
    const at = t.closest<HTMLElement>('[data-artetog]');
    if (at) { OPEN.arte[at.dataset.artetog!] = !OPEN.arte[at.dataset.artetog!]; renderArtes(); return; }
  });

  // idrow + budget
  document.querySelectorAll<HTMLInputElement>('.idrow .txt').forEach((inp) => inp.addEventListener('input', () => { S.id[inp.dataset.id!] = inp.value; save(); }));
  (el('xpBudget') as HTMLInputElement).addEventListener('input', (e) => { S.budget = +(e.target as HTMLInputElement).value || 0; recompute(); });

  function syncInputs() {
    document.querySelectorAll<HTMLInputElement>('.idrow .txt').forEach((inp) => (inp.value = S.id?.[inp.dataset.id!] || ''));
    (el('xpBudget') as HTMLInputElement).value = String(S.budget ?? 400);
  }
  function markModo() {
    document.querySelectorAll<HTMLElement>('.modo-toggle .btn').forEach((b) => { const on = b.dataset.modo === (S.modo || 'criacao'); b.classList.toggle('primary', on); b.setAttribute('aria-pressed', String(on)); });
  }
  function clampToMode() {
    // ao entrar em Criação, respeita os tetos (reduz o que passou)
    (ATTRS_D as any[]).forEach((a) => (S.attrs[a.id] = Math.min(S.attrs[a.id] || 2, capFor('attr'))));
    (HAB_D as any[]).forEach((h) => { S.skills[h.id] = Math.min(S.skills[h.id] || 0, capFor('skill')); if ((S.spec[h.id] || 0) > S.skills[h.id]) S.spec[h.id] = S.skills[h.id]; });
    SECONDARY.forEach(([n]) => { const k = slug(n); S.skills2[k] = Math.min(S.skills2[k] || 0, capFor('skill2')); if ((S.spec2[k] || 0) > S.skills2[k]) S.spec2[k] = S.skills2[k]; });
    S.centelha = Math.min(S.centelha || 0, capFor('centelha'));
  }
  function setModo(m: string) { S.modo = m; if (m === 'criacao') clampToMode(); renderAll(); }
  function renderAll() { syncInputs(); markModo(); renderAttrs(); renderPower(); renderSkills(); renderSecondary(); renderCaminhos(); renderArtes(); recompute(); }

  // botões
  document.querySelectorAll<HTMLElement>('.modo-toggle .btn').forEach((b) => b.addEventListener('click', () => setModo(b.dataset.modo!)));
  el('f-export').addEventListener('click', () => {
    const blob = new Blob([JSON.stringify(S, null, 2)], { type: 'application/json' });
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
    a.download = (S.id?.nome ? slug(S.id.nome) : 'ficha') + '.json'; a.click(); setTimeout(() => URL.revokeObjectURL(a.href), 2000);
  });
  el('f-import').addEventListener('click', () => el('f-file').click());
  el('f-file').addEventListener('change', (e) => {
    const f = (e.target as HTMLInputElement).files?.[0]; if (!f) return;
    const r = new FileReader(); r.onload = () => { try { S = JSON.parse(String(r.result)); normalize(); renderAll(); } catch { alert('Arquivo JSON inválido.'); } }; r.readAsText(f);
  });
  el('f-print').addEventListener('click', () => window.print());
  el('f-reset').addEventListener('click', () => { if (confirm('Limpar a ficha?')) { localStorage.removeItem(KEY); location.hash = ''; fresh(); renderAll(); } });
  el('f-link').addEventListener('click', () => {
    const b64 = btoa(unescape(encodeURIComponent(JSON.stringify(S))));
    navigator.clipboard?.writeText(location.origin + location.pathname + '#p=' + b64);
    const b = el('f-link'); b.textContent = '✓'; setTimeout(() => (b.textContent = 'Link'), 1200);
  });
  el('f-kael').addEventListener('click', () => {
    fresh();
    S.id = { nome: 'Kael, o Batedor', conceito: 'Batedor', jogador: '' };
    Object.assign(S.attrs, { destreza: 4, vigor: 3, percepcao: 3, raciocinio: 3 });
    Object.assign(S.skills, { furtividade: 3, 'armas-a-distancia': 3, prontidao: 2, atletismo: 2, sobrevivencia: 2, investigacao: 1, briga: 1, esquiva: 1 });
    Object.assign(S.spec, { furtividade: 1, 'armas-a-distancia': 1 });
    Object.assign(S.virtues, { conviccao: 2, temperanca: 2, valor: 3 });
    S.centelha = 1;
    S.tech = { 'pisar-leve': true, esgueirar: true, 'mira-firme': true };
    renderAll();
  });

  // init
  function init() {
    const m = location.hash.match(/p=([^&]+)/);
    if (m) { try { S = JSON.parse(decodeURIComponent(escape(atob(m[1])))); normalize(); return renderAll(); } catch {} }
    try { const raw = localStorage.getItem(KEY); if (raw) { S = JSON.parse(raw); normalize(); return renderAll(); } } catch {}
    fresh(); renderAll();
  }
  init();
</script>

