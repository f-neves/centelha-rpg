---
import Base from '../layouts/Base.astro';
import FichaSkeleton from '../components/FichaSkeleton.astro';
---
<Base title="Ficha de Personagem" largura="wide" descricao="Monte um personagem com XP ao vivo: atributos, habilidades, secundárias, Técnicas e Artes — tudo por bolinhas, com os derivados calculados.">
  <h1>Ficha de Personagem</h1>
  <FichaSkeleton />
</Base>

<script>
  import { montarFicha } from '../lib/ficha-engine';
  const KEY = 'centelha:ficha';
  montarFicha({
    carregar: () => {
      const m = location.hash.match(/p=([^&]+)/);
      if (m) { try { return JSON.parse(decodeURIComponent(escape(atob(m[1])))); } catch {} }
      try { const raw = localStorage.getItem(KEY); if (raw) return JSON.parse(raw); } catch {}
      return null;
    },
    salvar: (S) => { try { localStorage.setItem(KEY, JSON.stringify(S)); } catch {} },
    aoResetar: () => { try { localStorage.removeItem(KEY); } catch {}; location.hash = ''; },
  });
</script>
