---
// Ícones de traço (outline) por atributo e trilha. Herdam currentColor (adaptam ao tema).
interface Props { nome: string; size?: number; }
const { nome, size = 18 } = Astro.props;
const I: Record<string, string> = {
  // atributos
  forca: '<path d="M4 9v6M7 7v10M17 7v10M20 9v6M7 12h10"/>',
  destreza: '<path d="M5 5l7 7-7 7M12 5l7 7-7 7"/>',
  vigor: '<path d="M12 20s-7-4.4-7-10a3.6 3.6 0 0 1 7-1.3A3.6 3.6 0 0 1 19 10c0 5.6-7 10-7 10z"/>',
  carisma: '<circle cx="12" cy="12" r="3.6"/><path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5.2 5.2l1.8 1.8M17 17l1.8 1.8M18.8 5.2L17 7M7 17l-1.8 1.8"/>',
  manipulacao: '<circle cx="9" cy="12" r="4.6"/><circle cx="15" cy="12" r="4.6"/>',
  aparencia: '<path d="M6 4h12l3 5-9 11L3 9z"/><path d="M3 9h18M9 4L6 9l6 11 6-11-3-5"/>',
  percepcao: '<path d="M2 12s3.8-6.5 10-6.5S22 12 22 12s-3.8 6.5-10 6.5S2 12 2 12z"/><circle cx="12" cy="12" r="2.8"/>',
  inteligencia: '<path d="M12 5.5C9.5 3.8 6 3.8 3.5 4.8v13.4c2.5-1 6-1 8.5.7 2.5-1.7 6-1.7 8.5-.7V4.8C18 3.8 14.5 3.8 12 5.5zM12 5.5v13.6"/>',
  raciocinio: '<path d="M13 2.5L4.5 13.5H11l-2 8 9-11.5H11l2-7.5z"/>',
  // trilhas
  corpo: '<circle cx="12" cy="4.6" r="2.4"/><path d="M12 8v6.5M6.5 11l5.5-2.5L17.5 11M8.5 21l3.5-6 3.5 6"/>',
  voz: '<path d="M4 9.5v5h3.5L13 19V5L7.5 9.5H4z"/><path d="M16.5 8.5a5 5 0 0 1 0 7M19 6.5a8 8 0 0 1 0 11"/>',
  mente: '<path d="M8 20.5v-2.2C6.2 17 5 14.7 5 12a7 7 0 0 1 14 0c0 2.7-1.2 5-3 6.3v2.2"/><path d="M9.5 11.5a2.5 2.5 0 0 1 5 0"/>',
};
const path = I[nome];
---
{path && (
  <svg class="icone" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={path} />
)}

<style>
  .icone { display: inline-block; vertical-align: -0.18em; flex: 0 0 auto; }
</style>
