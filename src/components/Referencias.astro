---
// Sistema unificado de referências: tooltips em termos + hovercards em links internos
// + modal local (clique abre na própria página). Carrega /ref-index.json sob demanda.
---
<dialog class="ref-modal" aria-label="Detalhe">
  <button class="ref-modal-x" aria-label="Fechar">✕</button>
  <div class="ref-modal-body"></div>
</dialog>
<script>
  type Ref = { id: string; tipo: string; nome: string; url: string; resumo: string; caminho?: string; termos: string[]; autolink: boolean };
  const BASE = import.meta.env.BASE_URL;
  let INDEX: Ref[] | null = null;
  const byHash: Record<string, Ref> = {};   // técnica/arte/termo por id (âncora)
  const byCaminho: Record<string, Ref> = {}; // caminho por slug
  const byRef: Record<string, Ref> = {};     // itens auto-linkáveis por id
  const byKey: Record<string, Ref> = {};     // tipo:id (chave única p/ fixados)
  const keyOf = (it: Ref) => it.tipo + ':' + it.id;
  const norm = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

  async function load() {
    if (INDEX) return INDEX;
    try { INDEX = await (await fetch(BASE + 'ref-index.json')).json(); }
    catch { INDEX = []; }
    for (const it of INDEX!) {
      if (it.tipo === 'termo' || it.tipo === 'técnica' || it.tipo === 'arte') byHash[it.id] = it;
      if (it.tipo === 'caminho') byCaminho[it.id] = it;
      if (it.autolink) byRef[it.id] = it;
      byKey[keyOf(it)] = it;
    }
    return INDEX!;
  }

  // 1) auto-link seguro na prosa (glossário + atributos/perícias/virtudes), 1ª ocorrência
  function autolink() {
    const scan = document.querySelector('main'); if (!scan || !INDEX) return;
    const entries: { needle: string; it: Ref }[] = [];
    for (const it of INDEX) if (it.autolink) for (const t of it.termos) entries.push({ needle: t, it });
    entries.sort((a, b) => b.needle.length - a.needle.length);
    const SKIP = new Set(['A', 'CODE', 'PRE', 'BUTTON', 'INPUT', 'SELECT', 'TEXTAREA', 'H1', 'H2', 'H3', 'H4', 'SCRIPT', 'STYLE', 'OPTION', 'LABEL']);
    const walker = document.createTreeWalker(scan, NodeFilter.SHOW_TEXT, {
      acceptNode(n) {
        const p = (n as Text).parentElement;
        if (!p || SKIP.has(p.tagName) || p.closest('.ref, .no-gloss, .arv-node, .badge')) return NodeFilter.FILTER_REJECT;
        return n.textContent && n.textContent.trim().length > 2 ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      },
    });
    const nodes: Text[] = []; let c: Node | null;
    while ((c = walker.nextNode())) nodes.push(c as Text);
    const used = new Set<string>();
    for (const node of nodes) {
      const text = node.textContent || ''; const nt = norm(text);
      for (const e of entries) {
        if (used.has(e.it.id)) continue;
        const nn = norm(e.needle); const i = nt.indexOf(nn); if (i < 0) continue;
        const before = i === 0 ? ' ' : nt[i - 1], after = i + nn.length >= nt.length ? ' ' : nt[i + nn.length];
        if (/[a-z0-9]/.test(before) || /[a-z0-9]/.test(after)) continue;
        used.add(e.it.id);
        const a = document.createElement('a');
        a.className = 'ref'; a.href = e.it.url; a.dataset.ref = e.it.id;
        a.textContent = text.slice(i, i + e.needle.length);
        const rest = node.splitText(i); rest.textContent = rest.textContent!.slice(e.needle.length);
        node.parentNode!.insertBefore(a, rest);
        break;
      }
    }
  }

  // 2) resolve a entidade de um elemento (auto-link, nó da árvore OU qualquer link interno)
  function entityFor(el: HTMLElement): Ref | null {
    if (el.dataset?.ref && byRef[el.dataset.ref]) return byRef[el.dataset.ref];
    if (el.dataset?.id && byHash[el.dataset.id]) return byHash[el.dataset.id]; // nós da Árvore de Técnicas
    const href = el.getAttribute('href'); if (!href) return null;
    let u: URL; try { u = new URL(href, location.href); } catch { return null; }
    if (u.origin !== location.origin) return null;
    const hash = u.hash.slice(1);
    if (hash && byHash[hash]) return byHash[hash];
    const seg = u.pathname.replace(/\/+$/, '').split('/').pop() || '';
    if (byCaminho[seg]) return byCaminho[seg];
    return null;
  }

  // 3) hovercard (interativo: dá pra fixar)
  let pop: HTMLDivElement | null = null;
  let currentIt: Ref | null = null;
  let hideTimer = 0;
  const hide = () => { pop?.remove(); pop = null; currentIt = null; };
  const scheduleHide = () => { clearTimeout(hideTimer); hideTimer = window.setTimeout(hide, 240); };
  const cancelHide = () => clearTimeout(hideTimer);
  function show(el: HTMLElement, it: Ref) {
    hide();
    currentIt = it;
    pop = document.createElement('div'); pop.className = 'ref-pop';
    const tag = document.createElement('span'); tag.className = 'ref-tipo'; tag.textContent = it.tipo.charAt(0).toUpperCase() + it.tipo.slice(1);
    const b = document.createElement('b'); b.textContent = it.nome;
    const r = document.createElement('span'); r.className = 'ref-resumo'; r.textContent = it.resumo;
    const bar = document.createElement('span'); bar.className = 'ref-bar';
    const go = document.createElement('a'); go.className = 'ref-go'; go.textContent = 'abrir →'; go.href = it.url;
    const pin = document.createElement('button'); pin.className = 'ref-pin'; pin.type = 'button'; pin.innerHTML = '📌 fixar <kbd>f</kbd>'; pin.title = 'Fixar na consulta (tecla f)';
    pin.addEventListener('click', (e) => { e.preventDefault(); addPin(it); hide(); });
    bar.append(go, pin);
    pop.append(tag, b, r, bar);
    pop.addEventListener('mouseenter', cancelHide);
    pop.addEventListener('mouseleave', scheduleHide);
    document.body.append(pop);
    const rect = el.getBoundingClientRect();
    pop.style.top = window.scrollY + rect.bottom + 6 + 'px'; pop.style.left = '0px';
    let left = Math.min(window.scrollX + rect.left, window.scrollX + document.documentElement.clientWidth - pop.offsetWidth - 10);
    pop.style.left = Math.max(8, left) + 'px';
  }
  const SEL = 'main a[href], main .ref, main .arv-node';
  const handle = (target: EventTarget | null) => {
    const el = (target as HTMLElement)?.closest?.(SEL) as HTMLElement | null;
    if (!el) return;
    cancelHide();
    if (!INDEX) { load().then(() => { const it = entityFor(el); if (it && el.matches(':hover')) show(el, it); }); return; }
    const it = entityFor(el); if (it) show(el, it);
  };
  document.addEventListener('mouseover', (e) => handle(e.target));
  document.addEventListener('mouseout', (e) => { if ((e.target as HTMLElement)?.closest?.(SEL)) scheduleHide(); });
  document.addEventListener('focusin', (e) => { const el = (e.target as HTMLElement).closest?.('.ref, .arv-node') as HTMLElement; if (el && INDEX) { const it = entityFor(el); if (it) show(el, it); } });
  document.addEventListener('focusout', scheduleHide);
  window.addEventListener('scroll', hide, { passive: true });
  // teclado: f fixa o cartão aberto; Esc fecha
  document.addEventListener('keydown', (e) => {
    const tag = document.activeElement?.tagName;
    if (e.key === 'Escape') { hide(); return; }
    if (e.key.toLowerCase() === 'f' && currentIt && pop && tag !== 'INPUT' && tag !== 'TEXTAREA') { e.preventDefault(); addPin(currentIt); hide(); }
  });

  // 3b) modal local — clique abre na própria página (em vez de navegar)
  const modal = document.querySelector('.ref-modal') as HTMLDialogElement | null;
  const esc = (s: string) => (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  function refModal(payload: { tipo?: string; nome?: string; descricao?: string; niveis?: any[]; url?: string }) {
    if (!modal) return;
    const body = modal.querySelector('.ref-modal-body')!;
    let h = `<div class="rm-head"><span class="ref-tipo">${esc(cap(payload.tipo || ''))}</span><b>${esc(payload.nome || '')}</b></div>`;
    if (payload.descricao) h += `<p class="rm-desc">${esc(payload.descricao)}</p>`;
    if (Array.isArray(payload.niveis) && payload.niveis.length) {
      h += '<div class="rm-niveis">';
      for (const n of payload.niveis) h += `<div class="rm-lv"><span class="rm-n">${n.nivel}</span><span>${n.rotulo ? `<b>${esc(n.rotulo)}</b> — ` : ''}${esc(n.texto)}</span></div>`;
      h += '</div>';
    }
    if (payload.url) h += `<a class="rm-go" href="${payload.url}">ver no livro →</a>`;
    body.innerHTML = h;
    if (!modal.open) modal.showModal();
  }
  const cap = (s = '') => s.charAt(0).toUpperCase() + s.slice(1);
  (window as any).refModal = refModal;
  const openModal = (it: Ref & { detalhe?: any }) => refModal({ tipo: it.tipo, nome: it.nome, descricao: it.detalhe?.descricao ?? it.resumo, niveis: it.detalhe?.niveis, url: it.url });
  function compareModal(list: any[]) {
    if (!modal || !list.length) return;
    const body = modal.querySelector('.ref-modal-body')!;
    let h = '<div class="rm-compare">';
    for (const it of list) {
      h += `<div class="rm-col"><span class="ref-tipo">${esc(cap(it.tipo))}</span><b class="rm-cnome">${esc(it.nome)}</b><p class="rm-cdesc">${esc(it.detalhe?.descricao ?? it.resumo ?? '')}</p>`;
      if (Array.isArray(it.detalhe?.niveis)) h += '<div class="rm-niveis">' + it.detalhe.niveis.map((n: any) => `<div class="rm-lv"><span class="rm-n">${n.nivel}</span><span>${n.rotulo ? `<b>${esc(n.rotulo)}</b> ` : ''}${esc(n.texto)}</span></div>`).join('') + '</div>';
      h += `<a class="rm-go" href="${it.url}">abrir →</a></div>`;
    }
    body.innerHTML = h + '</div>';
    modal.classList.add('wide');
    if (!modal.open) modal.showModal();
  }
  (window as any).compareModal = compareModal;
  modal?.querySelector('.ref-modal-x')?.addEventListener('click', () => modal.close());
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
  modal?.addEventListener('close', () => modal.classList.remove('wide'));
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest?.('main a[href], main .ref') as HTMLElement | null;
    if (!el || !INDEX) return;
    let it: any = null;
    if (el.classList.contains('ref') || el.dataset?.ref) it = entityFor(el);
    else { try { const u = new URL((el as HTMLAnchorElement).href, location.href); const hash = u.hash.slice(1); if (hash && byHash[hash]) it = byHash[hash]; } catch {} }
    if (!it) return;
    e.preventDefault(); hide(); openModal(it);
  });

  // 4) painel de consulta (fixados) — persiste na sessão entre páginas
  const PIN_KEY = 'centelha:consulta';
  const pins = (): string[] => { try { return JSON.parse(sessionStorage.getItem(PIN_KEY) || '[]'); } catch { return []; } };
  const savePins = (a: string[]) => sessionStorage.setItem(PIN_KEY, JSON.stringify([...new Set(a)]));
  function addPin(it: Ref) { const a = pins(); a.push(keyOf(it)); savePins(a); renderConsulta(); }
  function removePin(key: string) { savePins(pins().filter((k) => k !== key)); renderConsulta(); }
  function renderConsulta() {
    let panel = document.getElementById('consulta');
    const list = pins().map((k) => byKey[k]).filter(Boolean);
    if (!list.length) { panel?.remove(); markPinned(); return; }
    if (!panel) {
      panel = document.createElement('aside'); panel.id = 'consulta'; panel.setAttribute('aria-label', 'Consulta fixada');
      document.body.append(panel);
    }
    const filtro = list.length >= 4 ? `<input class="cs-filter" type="search" placeholder="filtrar fixados…" aria-label="Filtrar fixados">` : '';
    const cmp = list.length >= 2 ? `<button class="cs-comparar" title="Comparar lado a lado">comparar</button>` : '';
    panel.innerHTML = `<div class="cs-head"><span>📌 Consulta <span class="cs-n">${list.length}</span></span>${cmp}<button class="cs-clear" title="Limpar">limpar</button></div>${filtro}`;
    for (const it of list) {
      const card = document.createElement('div'); card.className = 'cs-card';
      card.dataset.txt = (it.nome + ' ' + it.tipo + ' ' + it.resumo).toLowerCase();
      card.innerHTML = `<span class="ref-tipo">${cap(it.tipo)}</span><a href="${it.url}"><b>${it.nome}</b></a><button class="cs-x" aria-label="Remover" data-k="${keyOf(it)}">✕</button><span class="cs-resumo"></span>`;
      card.querySelector('.cs-resumo')!.textContent = it.resumo;
      panel.append(card);
    }
    panel.querySelector('.cs-clear')?.addEventListener('click', () => { savePins([]); renderConsulta(); });
    panel.querySelector('.cs-comparar')?.addEventListener('click', () => compareModal(list));
    panel.querySelectorAll('.cs-x').forEach((b) => b.addEventListener('click', () => removePin((b as HTMLElement).dataset.k!)));
    panel.querySelector('.cs-filter')?.addEventListener('input', (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      panel!.querySelectorAll<HTMLElement>('.cs-card').forEach((c) => { c.style.display = !q || c.dataset.txt!.includes(q) ? '' : 'none'; });
    });
    markPinned();
  }

  // realça no texto os links/termos das entidades fixadas
  function markPinned() {
    if (!INDEX) return;
    const set = new Set(pins());
    document.querySelectorAll<HTMLElement>(SEL).forEach((el) => {
      const it = entityFor(el);
      el.classList.toggle('ref-pinned', !!(it && set.has(keyOf(it))));
    });
  }

  // init: carrega o índice no idle, faz o auto-link e restaura a consulta
  const start = () => load().then(() => { autolink(); renderConsulta(); });
  if ('requestIdleCallback' in window) (window as any).requestIdleCallback(start); else setTimeout(start, 200);
</script>

<!-- is:global porque os elementos (auto-links, hovercard, consulta, modal) são criados via JS -->
<style is:global>
  .ref { color: var(--accent); text-decoration: underline; text-decoration-style: dotted; text-decoration-thickness: 1px; text-underline-offset: .15em; cursor: pointer; }
  .ref:hover { color: var(--accent-strong); }
  .ref-pop { position: absolute; z-index: 60; max-width: 24rem; background: var(--panel); color: var(--ink);
    border: 1px solid var(--accent); border-radius: 7px; padding: .55rem .7rem; box-shadow: 0 6px 20px var(--shadow);
    font-size: .9rem; line-height: 1.4; font-style: normal; pointer-events: auto; }
  .ref-tipo { display: inline-block; font-family: 'Cinzel'; font-size: .62rem; letter-spacing: .08em; text-transform: uppercase;
    background: var(--accent); color: var(--on-accent); border-radius: 999px; padding: .05rem .5rem; margin-right: .4rem; vertical-align: middle; }
  .ref-pop b { font-family: 'Cinzel'; color: var(--accent); font-size: .98rem; }
  .ref-pop .ref-resumo { display: block; margin: .25rem 0 .35rem; color: var(--ink); }
  .ref-pop .ref-bar { display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
  .ref-pop .ref-go { font-size: .78rem; color: var(--accent); font-style: italic; text-decoration: none; }
  .ref-pop .ref-pin { font-family: 'Cinzel'; font-size: .72rem; cursor: pointer; border: 1px solid var(--panel-border);
    background: var(--panel-2); color: var(--ink-soft); border-radius: 5px; padding: .12rem .45rem; }
  .ref-pop .ref-pin:hover { border-color: var(--accent); color: var(--accent); }
  .ref-pop .ref-pin kbd { font-family: monospace; font-size: .7em; border: 1px solid var(--panel-border); border-radius: 3px; padding: 0 .25em; margin-left: .15em; }

  /* realce de entidades fixadas no texto */
  .ref-pinned { background: color-mix(in srgb, var(--gold) 24%, transparent); border-radius: 3px; box-shadow: 0 0 0 1px color-mix(in srgb, var(--gold) 35%, transparent); }
  .arv-node.ref-pinned { background: color-mix(in srgb, var(--gold) 20%, var(--panel)); box-shadow: 0 0 0 2px var(--gold); }

  /* painel de consulta (fixados) */
  #consulta { position: fixed; right: .8rem; bottom: .8rem; z-index: 55; width: min(20rem, 90vw); max-height: 60vh; overflow-y: auto;
    background: var(--panel); border: 1px solid var(--accent); border-radius: 9px; box-shadow: 0 8px 28px var(--shadow); }
  #consulta .cs-head { position: sticky; top: 0; display: flex; justify-content: space-between; align-items: center;
    background: var(--accent); color: var(--on-accent); font-family: 'Cinzel'; font-size: .82rem; padding: .4rem .7rem; }
  #consulta .cs-clear { background: none; border: 1px solid var(--on-accent); color: var(--on-accent); border-radius: 4px; font-size: .68rem; cursor: pointer; padding: .05rem .4rem; font-family: 'Cinzel'; }
  #consulta .cs-n { background: var(--on-accent); color: var(--accent); border-radius: 999px; font-size: .68rem; padding: 0 .4rem; margin-left: .2rem; }
  #consulta .cs-filter { width: calc(100% - 1.4rem); margin: .5rem .7rem 0; padding: .3rem .45rem; border: 1px solid var(--panel-border); border-radius: 4px; background: var(--bg); color: var(--ink); font-size: .85rem; }
  #consulta .cs-card { padding: .5rem .7rem; border-bottom: 1px solid var(--rule); position: relative; }
  #consulta .cs-card a { text-decoration: none; }
  #consulta .cs-card b { font-family: 'Cinzel'; color: var(--accent); }
  #consulta .cs-resumo { display: block; font-size: .82rem; color: var(--ink-soft); margin-top: .2rem; }
  #consulta .cs-x { position: absolute; top: .35rem; right: .4rem; background: none; border: none; color: var(--ink-soft); cursor: pointer; font-size: .8rem; }
  @media (max-width: 620px) { #consulta { right: .4rem; left: .4rem; width: auto; } }

  /* modal local */
  .ref-modal { width: min(34rem, 92vw); border: 1px solid var(--accent); border-radius: 10px; padding: 1.1rem 1.2rem 1.3rem;
    background: var(--panel); color: var(--ink); box-shadow: 0 14px 50px var(--shadow); position: relative; }
  .ref-modal::backdrop { background: rgba(0,0,0,.5); }
  .ref-modal-x { position: absolute; top: .5rem; right: .6rem; background: none; border: none; font-size: 1.1rem; color: var(--ink-soft); cursor: pointer; }
  .rm-head { display: flex; align-items: center; gap: .5rem; margin-bottom: .4rem; }
  .rm-head b { font-family: 'Cinzel'; color: var(--accent); font-size: 1.25rem; }
  .rm-desc { margin: 0 0 .7rem; }
  .rm-niveis { border-top: 1px solid var(--rule); padding-top: .5rem; }
  .rm-lv { display: flex; gap: .6rem; align-items: baseline; padding: .22rem 0; font-size: .95rem; line-height: 1.4; }
  .rm-lv .rm-n { flex: 0 0 1.5rem; height: 1.5rem; display: inline-grid; place-items: center; background: var(--accent); color: var(--on-accent); font-family: 'Cinzel'; font-size: .8rem; border-radius: 50%; }
  .rm-lv b { color: var(--accent-strong); font-family: 'Cinzel'; font-size: .85rem; }
  .rm-go { display: inline-block; margin-top: .8rem; font-style: italic; color: var(--accent); text-decoration: none; }
  .ref-modal.wide { width: min(58rem, 95vw); }
  .rm-compare { display: flex; gap: 1rem; overflow-x: auto; padding-bottom: .4rem; }
  .rm-col { flex: 0 0 16rem; border: 1px solid var(--panel-border); border-radius: 8px; padding: .7rem .8rem; background: var(--panel-2); }
  .rm-col .rm-cnome { display: block; font-family: 'Cinzel'; color: var(--accent); font-size: 1.05rem; margin: .3rem 0; }
  .rm-col .rm-cdesc { font-size: .9rem; margin: 0 0 .5rem; }
  .cs-comparar { background: var(--on-accent); color: var(--accent); border: none; border-radius: 4px; font-size: .68rem; cursor: pointer; padding: .05rem .5rem; font-family: 'Cinzel'; margin-right: .3rem; }
</style>
