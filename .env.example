# Chaves do Supabase para a Area de Mestre e Jogadores.
# Copie este arquivo para .env e preencha com os valores do seu projeto Supabase
# (Painel do Supabase > Project Settings > API).
# O prefixo PUBLIC_ faz a Astro embutir o valor no cliente (sao chaves publicas por design;
# a seguranca real e a RLS no banco). O .env NAO vai para o git.

PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica
